const API = '/api/data';
const state = { data: { version:8, updatedAt:null, products:[], recipes:[], dietPlan:[], measurements:[], shoppingList:[], settings:{}, dayTemplates:[], backups:[] }, view:'dashboard', installPrompt:null, saving:false, productSearch:'', recipeSearch:'', recipeFilter:'all', planMode:'list', planWeekStart:null, loadedUpdatedAt:null, undoTimer:null, undoSnapshot:null, measurementRange:'90', recipeCollection:'all', selectedPlanDate:null };
const $ = (s,r=document)=>r.querySelector(s); const $$=(s,r=document)=>[...r.querySelectorAll(s)];
const uid=()=>crypto.randomUUID?.()||`${Date.now()}-${Math.random()}`;
const esc=(v='')=>String(v).replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
const num=v=>Number(v)||0; const fmt=v=>num(v).toLocaleString('pl-PL',{maximumFractionDigits:1});
function toast(msg,actionLabel='',action=null,duration=3000){const t=$('#toast');clearTimeout(t._timer);t.innerHTML=`<span>${esc(msg)}</span>${actionLabel?`<button type="button" id="toastAction">${esc(actionLabel)}</button>`:''}`;t.classList.remove('hidden');if(actionLabel&&action){$('#toastAction')?.addEventListener('click',async()=>{t.classList.add('hidden');await action()},{once:true})}t._timer=setTimeout(()=>t.classList.add('hidden'),duration)}
function setStatus(text,bad=false){const e=$('#syncStatus');e.textContent=text;e.style.color=bad?'#a62929':''}
const COMMON_UNITS=['sztuka','kromka','szklanka','łyżka','łyżeczka','garść','plaster','opakowanie'];
const SHOP_CATEGORIES=['Warzywa i owoce','Mięso i ryby','Nabiał i jaja','Pieczywo i wypieki','Produkty zbożowe','Przetwory i suche produkty','Tłuszcze','Przyprawy i dodatki','Inne'];
const MEAL_TIME_SUGGESTIONS={ 'Śniadanie':'08:00','II śniadanie':'11:00','Obiad':'15:00','Podwieczorek':'17:30','Kolacja':'20:00','Przekąska':'13:00','Inne':'12:00' };
function suggestedMealTime(mealType){return state.data.settings?.mealTimes?.[mealType]||MEAL_TIME_SUGGESTIONS[mealType]||'12:00'}
function inferProductCategory(name=''){const n=String(name).toLowerCase();const rules=[
  ['Warzywa i owoce',['jabł','banan','grusz','pomidor','ogór','papryk','cukini','marchew','broku','szpinak','sałat','cebula','czosnek','pietrusz','seler','rzodk','winogron','grejpfrut','ananas','cytryn','fasolka szparag','roszpon','kapust']],
  ['Mięso i ryby',['kurcz','indyk','dorsz','łoso','tuńczy','wołow','wieprz','szynk','wędlin','mięso','ryba']],
  ['Nabiał i jaja',['mleko','jogurt','kefir','ser ','serek','twar','feta','mozzarell','parmezan','gouda','ricotta','jaj']],
  ['Pieczywo i wypieki',['chleb','bułk','pieczyw','tortill','wafl']],
  ['Produkty zbożowe',['płatki','ryż','makaron','kasza','kuskus','mąka','otręb','polenta']],
  ['Przetwory i suche produkty',['fasola','ciecierzyc','kukurydz','hummus','oliwk','pomidor suszon','żurawin','rodzyn','śliwk suszon','dżem','orzech','migdał','słonecznik','pestk','sezam','siemię']],
  ['Tłuszcze',['oliwa','olej','masło','awokado']],
  ['Przyprawy i dodatki',['sól','pieprz','cynamon','zioła','oregano','bazyl','curry','musztard','ocet','kakao','miód','czekolad','wiórki kokos','koperek','szczypior']]
];for(const [cat,words] of rules)if(words.some(w=>n.includes(w)))return cat;return 'Inne'}
function normalizeCategory(category,name='',inferLegacyOther=false){const value=String(category||'').trim();if(SHOP_CATEGORIES.includes(value)&&!(inferLegacyOther&&value==='Inne'))return value;return inferProductCategory(name)}
function normalizeProductUnits(p){const baseUnit=p.baseUnit==='ml'?'ml':'g';const conversions=(p.conversions&&typeof p.conversions==='object')?p.conversions:{};return {...p,baseUnit,conversions}}
function unitFactor(p,unit){if(!p)return 1;if(unit===p.baseUnit)return 1;if(unit==='kg'&&p.baseUnit==='g')return 1000;if(unit==='l'&&p.baseUnit==='ml')return 1000;return num(p.conversions?.[unit])||1}
function ingredientBaseAmount(i,p){if(i.baseAmount!=null)return num(i.baseAmount);if(i.grams!=null)return num(i.grams);return num(i.amount)*unitFactor(p,i.unit||p?.baseUnit||'g')}
function ingredientDisplay(i,p){const unit=i.unit||p?.baseUnit||'g';const amount=i.amount!=null?num(i.amount):(ingredientBaseAmount(i,p)/unitFactor(p,unit));return `${fmt(amount)} ${unit}`}
function availableUnits(p){if(!p)return ['g'];const units=[p.baseUnit];if(p.baseUnit==='g')units.push('kg');if(p.baseUnit==='ml')units.push('l');for(const u of COMMON_UNITS)if(num(p.conversions?.[u])>0)units.push(u);return [...new Set(units)]}
async function load(){setStatus('Pobieranie danych online…');try{const controller=new AbortController();const timeout=setTimeout(()=>controller.abort(),15000);const r=await fetch(API,{cache:'no-store',signal:controller.signal});clearTimeout(timeout);const payload=await r.json().catch(()=>({}));if(!r.ok)throw Error(payload.error||`Błąd HTTP ${r.status}`);state.data=payload;state.data.shoppingList=Array.isArray(state.data.shoppingList)?state.data.shoppingList:[];state.data.dayTemplates=Array.isArray(state.data.dayTemplates)?state.data.dayTemplates:[];state.data.backups=Array.isArray(state.data.backups)?state.data.backups:[];state.data.settings={targets:{kcal:2100,protein:140,fat:70,carbs:230},mealTimes:{...MEAL_TIME_SUGGESTIONS},theme:'system',...(state.data.settings||{}),targets:{kcal:2100,protein:140,fat:70,carbs:230,...(state.data.settings?.targets||{})},mealTimes:{...MEAL_TIME_SUGGESTIONS,...(state.data.settings?.mealTimes||{})}};const legacyVersion=num(state.data.version)<3;state.data.products=(state.data.products||[]).map(p=>normalizeProductUnits({...p,category:normalizeCategory(p.category,p.name,legacyVersion),pantry:Boolean(p.pantry),packageSize:num(p.packageSize)||0,packagePrice:num(p.packagePrice)||0}));state.data.recipes=(state.data.recipes||[]).map(r=>({...r,favorite:Boolean(r.favorite),tags:Array.isArray(r.tags)?r.tags:[],prepTime:num(r.prepTime)||0,difficulty:r.difficulty||'Łatwy',notes:r.notes||'',collection:r.collection||''}));state.data.shoppingList=state.data.shoppingList.map(x=>({...x,category:normalizeCategory(x.category,x.name,legacyVersion)}));state.data.dietPlan=(state.data.dietPlan||[]).map(m=>({...m,portions:Math.max(0.25,num(m.portions)||1)}));state.data.version=8;state.loadedUpdatedAt=state.data.updatedAt||null;applyTheme();setStatus(state.data.updatedAt?`Zapisano: ${new Date(state.data.updatedAt).toLocaleString('pl-PL')}`:'Pusty plik danych – gotowe');render()}catch(e){setStatus(`Brak połączenia: ${e.message}`,true);toast('Nie udało się pobrać danych')}}
async function save(){if(state.saving)return;state.saving=true;setStatus('Zapisywanie do JSON…');try{const snapshot={at:new Date().toISOString(),data:{products:state.data.products,recipes:state.data.recipes,dietPlan:state.data.dietPlan,measurements:state.data.measurements,shoppingList:state.data.shoppingList,settings:state.data.settings,dayTemplates:state.data.dayTemplates}};state.data.backups=[snapshot,...(state.data.backups||[])].slice(0,5);const payload={...state.data,expectedUpdatedAt:state.loadedUpdatedAt};const r=await fetch(API,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const body=await r.json();if(r.status===409)throw Error('Dane zmieniono na innym urządzeniu. Kliknij Odśwież i powtórz zmianę.');if(!r.ok)throw Error(body.error);state.data=body;state.loadedUpdatedAt=body.updatedAt||null;applyTheme();setStatus(`Zapisano: ${new Date(body.updatedAt).toLocaleString('pl-PL')}`);toast('Dane zapisane online')}catch(e){setStatus(`Błąd zapisu: ${e.message}`,true);toast(e.message)}finally{state.saving=false;render()}}
function go(view){closePlanningPanel();state.view=view;$$('.view').forEach(e=>e.classList.toggle('active',e.id===view));$$('.tabs button,.mobile-nav button[data-view]').forEach(e=>e.classList.toggle('active',e.dataset.view===view));closeMore();renderView(view)}
function render(){renderView(state.view)}
function renderView(v){({dashboard:renderDashboard,products:renderProducts,recipes:renderRecipes,plan:renderPlan,shopping:renderShopping,measurements:renderMeasurements,settings:renderSettings}[v]||renderDashboard)()}
function head(title,action,label='Dodaj'){return `<div class="section-head"><h2>${title}</h2>${action?`<button class="primary" data-action="${action}">+ ${label}</button>`:''}</div>`}
function empty(t,action='',label='Dodaj'){const hint=action?'Możesz rozpocząć od poniższego działania.':'Zmień filtry albo dodaj nowe dane, aby zobaczyć je w tym miejscu.';return `<div class="empty-state" role="status"><div class="empty-icon" aria-hidden="true">＋</div><h3>${t}</h3><p>${hint}</p>${action?`<button class="primary" data-action="${action}">${label}</button>`:''}</div>`}
function closeMore(){const s=$('#moreSheet');if(s){s.classList.add('hidden');s.setAttribute('aria-hidden','true')}}
function openMore(){const s=$('#moreSheet');if(s){s.classList.remove('hidden');s.setAttribute('aria-hidden','false')}}
function actionMenu(items){return `<details class="action-menu"><summary aria-label="Więcej działań">⋮</summary><div class="action-menu-pop">${items.join('')}</div></details>`}
function openModal(title,html,onSubmit){const modal=$('#modal'),titleEl=$('#modalTitle'),form=$('#modalForm');if(!modal||!titleEl||!form)return;delete modal.dataset.recipeDirty;delete modal.dataset.modalType;delete modal.dataset.recipeDraftKey;titleEl.textContent=title;form.innerHTML=html;form.onsubmit=e=>{e.preventDefault();if(typeof onSubmit==='function')onSubmit(new FormData(form))};modal.classList.remove('hidden');requestAnimationFrame(()=>{const first=form.querySelector('input:not([type=hidden]),select,textarea,button');first?.focus()})}
async function closeModal(force=false){const modal=$('#modal'),form=$('#modalForm');if(!modal||!form)return;if(!force&&modal.dataset.modalType==='recipe'&&modal.dataset.recipeDirty==='true'){const ok=await unsavedChangesDialog();if(!ok)return}if(typeof modal._confirmCleanup==='function'){modal._confirmCleanup();modal._confirmCleanup=null}modal.classList.add('hidden');form.innerHTML='';form.onsubmit=null;delete modal.dataset.recipeDirty;delete modal.dataset.modalType;delete modal.dataset.recipeDraftKey} 
function unsavedChangesDialog(){return new Promise(resolve=>{let box=document.getElementById('unsavedDialog');if(box)box.remove();box=document.createElement('div');box.id='unsavedDialog';box.className='confirm-overlay';box.innerHTML=`<div class="confirm-card" role="alertdialog" aria-modal="true" aria-labelledby="unsavedTitle"><h3 id="unsavedTitle">Niezapisane zmiany</h3><p>Zmiany w przepisie nie zostały zapisane. Szkic pozostanie dostępny przy następnym otwarciu formularza.</p><div class="form-actions"><button type="button" class="secondary" data-unsaved-cancel>Wróć do edycji</button><button type="button" class="danger-btn" data-unsaved-confirm>Zamknij formularz</button></div></div>`;document.body.appendChild(box);const done=v=>{box.remove();resolve(v)};box.querySelector('[data-unsaved-cancel]').onclick=()=>done(false);box.querySelector('[data-unsaved-confirm]').onclick=()=>done(true);box.addEventListener('click',e=>{if(e.target===box)done(false)});box.querySelector('[data-unsaved-cancel]').focus()})}
function confirmDialog({title='Potwierdź',message='',confirmLabel='Potwierdź',danger=false}={}){return new Promise(resolve=>{openModal(title,`<div class="confirm-copy"><p>${esc(message).replace(/\n/g,'<br>')}</p></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button type="submit" class="${danger?'danger-btn':'primary'}">${esc(confirmLabel)}</button></div>`,()=>{closeModal();resolve(true)});const close=$('#modalClose');const cancel=$('#modalForm [data-close]');const oldClose=close?.onclick;const cancelHandler=()=>{closeModal();resolve(false)};if(close)close.onclick=cancelHandler;if(cancel)cancel.onclick=cancelHandler;$('#modal')._confirmCleanup=()=>{if(close)close.onclick=oldClose}})}
function productById(id){return state.data.products.find(x=>x.id===id)} function recipeById(id){return state.data.recipes.find(x=>x.id===id)}
function recipeNutrition(r){return (r.ingredients||[]).reduce((a,i)=>{const p=productById(i.productId);const q=ingredientBaseAmount(i,p)/100;if(p){a.kcal+=num(p.kcal)*q;a.protein+=num(p.protein)*q;a.fat+=num(p.fat)*q;a.carbs+=num(p.carbs)*q}return a},{kcal:0,protein:0,fat:0,carbs:0})}
function mealsNutrition(meals=[]){return meals.reduce((a,m)=>{const r=recipeById(m.recipeId);if(r){const n=recipeNutrition(r),portions=Math.max(0.25,num(m.portions)||1);a.kcal+=n.kcal*portions;a.protein+=n.protein*portions;a.fat+=n.fat*portions;a.carbs+=n.carbs*portions}return a},{kcal:0,protein:0,fat:0,carbs:0})}
function daySummaryHtml(meals=[]){const n=mealsNutrition(meals),t=state.data.settings?.targets||{};const bar=(label,val,target,unit)=>`<div class="goal-row"><div><span>${label}</span><strong>${fmt(val)} / ${fmt(target)} ${unit}</strong></div><progress max="${target||1}" value="${Math.min(val,target||1)}"></progress></div>`;return `<div class="day-summary"><div><strong>${fmt(n.kcal)}</strong><span>kcal</span></div><div><strong>${fmt(n.protein)} g</strong><span>białko</span></div><div><strong>${fmt(n.fat)} g</strong><span>tłuszcz</span></div><div><strong>${fmt(n.carbs)} g</strong><span>węglowodany</span></div></div><div class="goal-bars">${bar('Kalorie',n.kcal,num(t.kcal),'kcal')}${bar('Białko',n.protein,num(t.protein),'g')}${bar('Tłuszcz',n.fat,num(t.fat),'g')}${bar('Węglowodany',n.carbs,num(t.carbs),'g')}</div>`}
function applyTheme(){const theme=state.data.settings?.theme||'system';document.documentElement.dataset.theme=theme}
function planWarnings(meals){const w=[];const sorted=[...meals].sort((a,b)=>(a.time||'').localeCompare(b.time||''));for(let i=1;i<sorted.length;i++){const [h1,m1]=(sorted[i-1].time||'00:00').split(':').map(Number),[h2,m2]=(sorted[i].time||'00:00').split(':').map(Number);if((h2*60+m2)-(h1*60+m1)>360)w.push(`Długa przerwa między ${sorted[i-1].time} a ${sorted[i].time}.`)}if(!meals.some(m=>m.mealType==='Obiad'))w.push('Brak obiadu.');const n=mealsNutrition(meals),t=state.data.settings?.targets||{};if(t.kcal&&Math.abs(n.kcal-t.kcal)/t.kcal>.15)w.push(n.kcal<t.kcal?'Kaloryczność jest ponad 15% poniżej celu.':'Kaloryczność jest ponad 15% powyżej celu.');return w.length?`<div class="warnings">${w.map(x=>`<div>⚠ ${esc(x)}</div>`).join('')}</div>`:''}
function measurementFiltered(){const all=[...state.data.measurements].filter(x=>x.weight).sort((a,b)=>a.date.localeCompare(b.date));if(state.measurementRange==='all')return all;const days=num(state.measurementRange)||90;const cutoff=new Date();cutoff.setDate(cutoff.getDate()-days);const iso=cutoff.toISOString().slice(0,10);return all.filter(x=>x.date>=iso)}
function movingAverage(values,windowSize=7){return values.map((_,i)=>{const slice=values.slice(Math.max(0,i-windowSize+1),i+1);return slice.reduce((a,b)=>a+b,0)/slice.length})}
function measurementChartHtml(){const pts=measurementFiltered();if(pts.length<2)return '<p>Dodaj co najmniej dwa pomiary masy ciała w wybranym zakresie.</p>';const vals=pts.map(x=>num(x.weight)),avg=movingAverage(vals,7),min=Math.min(...vals,...avg)-1,max=Math.max(...vals,...avg)+1,w=700,h=220;const coords=arr=>arr.map((v,i)=>({x:30+i*(w-60)/(arr.length-1),y:20+(max-v)*(h-50)/(max-min)}));const raw=coords(vals),ma=coords(avg);const change=vals.at(-1)-vals[0],weeks=Math.max(1,(new Date(pts.at(-1).date)-new Date(pts[0].date))/604800000),pace=change/weeks;return `<div class="progress-summary"><div><span>Aktualnie</span><strong>${fmt(vals.at(-1))} kg</strong></div><div><span>Zmiana</span><strong>${change>0?'+':''}${fmt(change)} kg</strong></div><div><span>Tempo</span><strong>${pace>0?'+':''}${fmt(pace)} kg/tydz.</strong></div><div><span>Pomiary</span><strong>${pts.length}</strong></div></div><svg class="weight-chart" viewBox="0 0 ${w} ${h}" role="img" aria-label="Wykres masy ciała"><polyline points="${raw.map(p=>`${p.x},${p.y}`).join(' ')}" fill="none" stroke="currentColor" stroke-width="2" opacity=".45"/><polyline points="${ma.map(p=>`${p.x},${p.y}`).join(' ')}" fill="none" stroke="var(--primary,#2f855a)" stroke-width="4"/>${raw.map((p,i)=>`<circle cx="${p.x}" cy="${p.y}" r="4"><title>${pts[i].date}: ${pts[i].weight} kg</title></circle>`).join('')}</svg><div class="chart-legend"><span>● Pomiary</span><span>━ Średnia 7-dniowa</span></div>`}
function renderMeasurements(){const list=[...state.data.measurements].sort((a,b)=>b.date.localeCompare(a.date));$('#measurements').innerHTML=`${head('Pomiary','add-measurement')}<div class="panel"><div class="panel-title"><h3>Postępy masy ciała</h3><select id="measurementRange"><option value="30" ${state.measurementRange==='30'?'selected':''}>30 dni</option><option value="90" ${state.measurementRange==='90'?'selected':''}>90 dni</option><option value="365" ${state.measurementRange==='365'?'selected':''}>Rok</option><option value="all" ${state.measurementRange==='all'?'selected':''}>Cały okres</option></select></div>${measurementChartHtml()}</div><div style="height:14px"></div><div class="list">${list.length?list.map(m=>`<article class="item"><div><h3>${esc(m.date)}</h3><p>Masa: ${m.weight?fmt(m.weight)+' kg':'—'} · Talia: ${m.waist?fmt(m.waist)+' cm':'—'} · Klatka: ${m.chest?fmt(m.chest)+' cm':'—'}</p><p>${esc(m.notes||'')}</p></div><div class="item-actions"><button class="icon-btn" data-edit-measurement="${m.id}" title="Edytuj pomiar" aria-label="Edytuj pomiar"><span aria-hidden="true">✎</span></button><button class="icon-btn danger" data-delete-measurement="${m.id}" title="Usuń pomiar" aria-label="Usuń pomiar"><span aria-hidden="true">🗑</span></button></div></article>`).join(''):empty('Brak pomiarów.')}</div>`;$('#measurementRange').onchange=e=>{state.measurementRange=e.target.value;renderMeasurements()}}
function weekStart(date=new Date()){const d=new Date(typeof date==='string'?date+'T12:00:00':date);const day=(d.getDay()+6)%7;d.setDate(d.getDate()-day);return d.toISOString().slice(0,10)}
function weeklyPlanHtml(list){
  const start=state.planWeekStart||weekStart();
  const days=Array.from({length:7},(_,i)=>shiftIsoDate(start,i));
  const types=['Śniadanie','II śniadanie','Obiad','Podwieczorek','Kolacja','Przekąska','Inne'];
  const rangeLabel=`${new Date(start+'T12:00').toLocaleDateString('pl-PL',{day:'2-digit',month:'2-digit'})}–${new Date(days[6]+'T12:00').toLocaleDateString('pl-PL',{day:'2-digit',month:'2-digit',year:'numeric'})}`;
  return `<div class="week-nav panel"><button class="secondary" data-action="previous-week">← Poprzedni</button><strong>${rangeLabel}</strong><button class="secondary" data-action="current-week">Bieżący tydzień</button><button class="secondary" data-action="next-week">Następny →</button></div>${mobileWeekHtml(list,days)}<div class="weekly-wrap desktop-week"><table class="weekly-table"><thead><tr><th>Posiłek</th>${days.map(d=>{const dayMeals=list.filter(m=>m.date===d),n=mealsNutrition(dayMeals);return `<th><div class="week-day-head"><span>${new Date(d+'T12:00').toLocaleDateString('pl-PL',{weekday:'short',day:'2-digit',month:'2-digit'})}</span><button type="button" class="week-delete-day" data-delete-day="${d}" title="Usuń cały dzień" aria-label="Usuń wszystkie posiłki z dnia ${d}">🗑</button></div><small>${fmt(n.kcal)} kcal · ${dayMeals.length} pos.</small></th>`}).join('')}</tr></thead><tbody>${types.map(t=>`<tr><th>${t}</th>${days.map(d=>{const ms=list.filter(m=>m.date===d&&m.mealType===t);return `<td>${ms.map(m=>`<div class="week-meal-entry"><button type="button" class="week-meal" data-meal-details="${m.id}"><strong>${esc(recipeById(m.recipeId)?.name||'—')}</strong><small>${esc(m.time||'')} · ${fmt(m.portions||1)} por.</small></button><button type="button" class="week-delete-meal" data-delete-meal="${m.id}" title="Usuń posiłek" aria-label="Usuń posiłek"><span aria-hidden="true">🗑</span></button></div>`).join('')}<button class="week-add" data-quick-add-date="${d}" data-quick-add-type="${esc(t)}">＋</button></td>`}).join('')}</tr>`).join('')}</tbody><tfoot><tr><th>Suma dnia</th>${days.map(d=>{const n=mealsNutrition(list.filter(m=>m.date===d));return `<td><b>${fmt(n.kcal)} kcal</b><small>B ${fmt(n.protein)} · T ${fmt(n.fat)} · W ${fmt(n.carbs)}</small></td>`}).join('')}</tr></tfoot></table></div>`
}

function mobileWeekHtml(list,days){
  let selected=state.selectedPlanDate;
  if(!days.includes(selected))selected=days[0];
  state.selectedPlanDate=selected;
  const items=list.filter(m=>m.date===selected).sort((a,b)=>(a.time||'').localeCompare(b.time||''));
  const idx=days.indexOf(selected),prev=days[Math.max(0,idx-1)],next=days[Math.min(days.length-1,idx+1)];
  return `<div class="mobile-day-planner"><div class="mobile-day-switcher"><button class="icon-btn" data-mobile-day="${prev}" ${idx===0?'disabled':''} aria-label="Poprzedni dzień">‹</button><button class="mobile-date-button" data-day-details="${selected}"><strong>${new Date(selected+'T12:00').toLocaleDateString('pl-PL',{weekday:'long'})}</strong><span>${new Date(selected+'T12:00').toLocaleDateString('pl-PL',{day:'numeric',month:'long'})}</span></button><button class="icon-btn" data-mobile-day="${next}" ${idx===days.length-1?'disabled':''} aria-label="Następny dzień">›</button></div><div class="mobile-day-status">${dayCompletenessHtml(selected,items)}</div><div class="mobile-day-meals">${items.length?items.map(m=>`<div class="mobile-meal-row"><button data-meal-details="${m.id}"><time>${esc(m.time||'--:--')}</time><span><b>${esc(m.mealType||'Posiłek')}</b><small>${esc(recipeById(m.recipeId)?.name||'—')}</small></span></button>${actionMenu([`<button data-meal-details="${m.id}">Szczegóły</button>`,`<button data-copy-meal="${m.id}">Kopiuj</button>`,`<button data-repeat-meal="${m.id}">Powtarzaj</button>`,`<button data-move-meal="${m.id}">Przenieś</button>`,`<button class="danger-text" data-delete-meal="${m.id}">Usuń</button>`])}</div>`).join(''):empty('Brak posiłków','quick-add-meal','Dodaj posiłek')}</div><div class="mobile-plan-actions"><button class="primary" data-quick-add-date="${selected}">+ Posiłek</button><button class="secondary" data-day-details="${selected}">Podsumowanie</button></div></div>`;
}
function copyPreviousWeek(){const defaultTarget=state.planWeekStart||weekStart();openModal('Kopiuj poprzedni tydzień',`<div class="form-grid"><label class="full">Poniedziałek tygodnia docelowego<input name="target" type="date" required value="${defaultTarget}"></label><label class="full"><input name="replace" type="checkbox" checked> Zastąp istniejące posiłki w tygodniu docelowym</label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Kopiuj tydzień</button></div>`,async fd=>{const target=weekStart(fd.get('target')),source=shiftIsoDate(target,-7),sourceEnd=shiftIsoDate(source,6),src=state.data.dietPlan.filter(m=>m.date>=source&&m.date<=sourceEnd);if(!src.length)return toast('Poprzedni tydzień jest pusty');if(fd.get('replace')==='on')state.data.dietPlan=state.data.dietPlan.filter(m=>m.date<target||m.date>shiftIsoDate(target,6));state.data.dietPlan.push(...src.map(m=>({...m,id:uid(),date:shiftIsoDate(m.date,7)})));state.planWeekStart=target;closeModal();await save();toast(`Skopiowano ${src.length} posiłków`)})}
function copyDayToDatesForm(){const today=state.copySourceDate||new Date().toISOString().slice(0,10);state.copySourceDate=null;openModal('Kopiuj dzień na wybrane daty',`<div class="form-grid"><label>Data źródłowa<input name="source" type="date" required value="${today}"></label><label class="full">Daty docelowe<input name="targets" required placeholder="np. 2026-06-22, 2026-06-24, 2026-06-26"><small class="field-help">Wpisz daty oddzielone przecinkami.</small></label><label class="full"><input name="replace" type="checkbox" checked> Zastąp istniejące posiłki w datach docelowych</label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Kopiuj</button></div>`,async fd=>{const source=fd.get('source'),targets=String(fd.get('targets')||'').split(',').map(x=>x.trim()).filter(x=>/^\d{4}-\d{2}-\d{2}$/.test(x)&&x!==source),src=state.data.dietPlan.filter(m=>m.date===source);if(!src.length)return toast('Dzień źródłowy jest pusty');if(!targets.length)return toast('Podaj co najmniej jedną poprawną datę');if(fd.get('replace')==='on')state.data.dietPlan=state.data.dietPlan.filter(m=>!targets.includes(m.date));for(const date of targets)state.data.dietPlan.push(...src.map(m=>({...m,id:uid(),date})));closeModal();await save();toast(`Skopiowano dzień na ${targets.length} dat`)})}
function templatesForm(){const templates=state.data.dayTemplates||[],today=new Date().toISOString().slice(0,10);openModal('Szablony dni',`<div class="form-grid"><label>Data<input name="date" type="date" required value="${today}"></label><label>Operacja<select name="mode" id="templateMode"><option value="save">Zapisz dzień jako nowy szablon</option><option value="apply">Zastosuj istniejący szablon</option></select></label><label class="full" id="templateNameWrap">Nazwa szablonu<input name="name" value="Dzień pracy"></label><label class="full hidden" id="templateSelectWrap">Szablon<select name="templateId">${templates.map(t=>`<option value="${t.id}">${esc(t.name)}</option>`).join('')}</select></label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zapisz</button></div>`,async fd=>{const date=fd.get('date'),mode=fd.get('mode');if(mode==='save'){const meals=state.data.dietPlan.filter(m=>m.date===date).map(({id,date,...x})=>x),name=String(fd.get('name')||'').trim();if(!meals.length)return toast('Wybrany dzień jest pusty');if(!name)return toast('Podaj nazwę szablonu');state.data.dayTemplates.push({id:uid(),name,meals})}else{const t=templates.find(x=>x.id===fd.get('templateId'));if(!t)return toast('Wybierz szablon');const existing=state.data.dietPlan.filter(m=>m.date===date);if(existing.length&&!await confirmDialog({title:'Zastąpić plan dnia?',message:`Dzień zawiera ${existing.length} posiłków.`,confirmLabel:'Zastąp'}))return;state.data.dietPlan=state.data.dietPlan.filter(m=>m.date!==date);state.data.dietPlan.push(...t.meals.map(m=>({...m,id:uid(),date})))}closeModal();await save();toast(mode==='save'?'Szablon zapisany':'Szablon zastosowany')});const mode=$('#templateMode'),toggle=()=>{$('#templateNameWrap').classList.toggle('hidden',mode.value!=='save');$('#templateSelectWrap').classList.toggle('hidden',mode.value!=='apply')};mode.onchange=toggle;toggle()}


/* Przywrócone funkcje widoków i eksportu — v20.1 */
function ensureXlsx(){if(!window.XLSX){toast('Nie udało się załadować obsługi Excel');throw Error('Biblioteka Excel jest niedostępna')}return window.XLSX}

function exportExcel(){
  const X=ensureXlsx();
  const wb=X.utils.book_new();
  const products=state.data.products.map(p=>({ID:p.id,Nazwa:p.name,Kategoria:p.category||'Inne',Jednostka_bazowa:p.baseUnit||'g',Przeliczniki_JSON:JSON.stringify(p.conversions||{}),Kalorie_100g:num(p.kcal),Bialko_100g:num(p.protein),Tluszcz_100g:num(p.fat),Weglowodany_100g:num(p.carbs)}));
  const recipes=state.data.recipes.map(r=>({ID:r.id,Nazwa:r.name,Typ_posilku:r.mealType||'',Kolekcja:r.collection||'',Tagi:(r.tags||[]).join(', '),Czas_przygotowania:r.prepTime||'',Trudnosc:r.difficulty||'',Przygotowanie:r.instructions||''}));
  const ingredients=state.data.recipes.flatMap(r=>(r.ingredients||[]).map(i=>{const p=productById(i.productId);return {ID_przepisu:r.id,Nazwa_przepisu:r.name,ID_produktu:i.productId,Nazwa_produktu:p?.name||'',Ilosc:num(i.amount??ingredientBaseAmount(i,p)),Jednostka:i.unit||p?.baseUnit||'g',Ilosc_bazowa:ingredientBaseAmount(i,p)}}));
  const plan=state.data.dietPlan.map(m=>{const r=recipeById(m.recipeId);return {ID:m.id,Data:m.date,Godzina:m.time||'',Typ_posilku:m.mealType||'',ID_przepisu:m.recipeId,Nazwa_przepisu:r?.name||'',Liczba_porcji:Math.max(0.25,num(m.portions)||1)}});
  const shopping=(state.data.shoppingList||[]).map(x=>({ID:x.id,Nazwa:x.name,Ilosc:num(x.amount),Jednostka:x.unit||'g',Kategoria:x.category||'Inne',Kupione:x.purchased?'TAK':'NIE',Zrodlo:x.source||'manual'}));
  const measurements=state.data.measurements.map(m=>({ID:m.id,Data:m.date,Masa_kg:m.weight??'',Talia_cm:m.waist??'',Klatka_cm:m.chest??'',Notatki:m.notes||''}));
  X.utils.book_append_sheet(wb,sheetFromRows(products,[38,28,26,14,14,14,19]),'Produkty');
  X.utils.book_append_sheet(wb,sheetFromRows(recipes,[38,30,18,60]),'Przepisy');
  X.utils.book_append_sheet(wb,sheetFromRows(ingredients,[38,30,38,28,12]),'Skladniki');
  X.utils.book_append_sheet(wb,sheetFromRows(plan,[38,14,10,18,38,30]),'Plan_diety');
  X.utils.book_append_sheet(wb,sheetFromRows(shopping,[38,28,12,12,26,10,12]),'Lista_zakupow');
  X.utils.book_append_sheet(wb,sheetFromRows(measurements,[38,14,12,12,12,45]),'Pomiary');
  X.writeFile(wb,`moja-dieta-${new Date().toISOString().slice(0,10)}.xlsx`);
}

function generateShopping(){const from=$('#shoppingFrom')?.value,to=$('#shoppingTo')?.value;if(!from||!to)return toast('Wybierz zakres dat');if(from>to)return toast('Data początkowa jest późniejsza niż końcowa');const totals=new Map();state.data.dietPlan.filter(m=>m.date>=from&&m.date<=to).forEach(m=>{const r=recipeById(m.recipeId);(r?.ingredients||[]).forEach(i=>{const p=productById(i.productId);if(!p||p.pantry)return;const key=p.id;const prev=totals.get(key)||{id:uid(),productId:p.id,name:p.name,amount:0,unit:p.baseUnit||'g',category:normalizeCategory(p.category,p.name),purchased:false,source:'plan',estimatedCost:0};prev.amount+=ingredientBaseAmount(i,p)*Math.max(0.25,num(m.portions)||1);prev.unit=p.baseUnit||'g';if(p.packageSize&&p.packagePrice)prev.estimatedCost=Math.ceil(prev.amount/p.packageSize)*p.packagePrice;totals.set(key,prev)})});const manual=(state.data.shoppingList||[]).filter(x=>x.source!=='plan');state.data.shoppingList=[...manual,...totals.values()];save()}

function mealHtml(m){const r=recipeById(m.recipeId),portions=Math.max(0.25,num(m.portions)||1);return `<div class="item meal-card"><div class="item-main"><span class="badge">${esc(m.mealType||'Posiłek')}</span><h3>${esc(m.time||'')} ${esc(r?.name||m.customName||'Brak przepisu')}</h3><p class="meal-portions">${fmt(portions)} ${portions===1?'porcja':'porcje'}</p>${r?recipeDetailsHtml(r,portions):'<p>Przepis nie jest już dostępny.</p>'}</div><div class="item-actions"><button class="icon-btn" data-edit-meal="${m.id}" title="Edytuj posiłek" aria-label="Edytuj posiłek"><span aria-hidden="true">✎</span></button><button class="icon-btn danger" data-delete-meal="${m.id}" title="Usuń posiłek" aria-label="Usuń posiłek"><span aria-hidden="true">🗑</span></button></div></div>`}

function recipeDetailsHtml(r,multiplier=1){if(!r)return '';const portions=Math.max(0.25,num(multiplier)||1),n=recipeNutrition(r);const ingredients=(r.ingredients||[]).map(i=>{const p=productById(i.productId);const unit=i.unit||p?.baseUnit||'g';const amount=(i.amount!=null?num(i.amount):(ingredientBaseAmount(i,p)/unitFactor(p,unit)))*portions;return `<li><span>${esc(p?.name||'Nieznany produkt')}</span><strong>${fmt(amount)} ${esc(unit)}</strong></li>`}).join('');return `<details class="recipe-details"><summary>Pokaż szczegóły przepisu</summary><div class="recipe-details-content"><div class="recipe-nutrition"><span>${fmt(n.kcal*portions)} kcal</span><span>B ${fmt(n.protein*portions)} g</span><span>T ${fmt(n.fat*portions)} g</span><span>W ${fmt(n.carbs*portions)} g</span></div><div><h4>Składniki${portions!==1?` dla ${fmt(portions)} porcji`:''}</h4>${ingredients?`<ul class="ingredient-list">${ingredients}</ul>`:'<p>Brak składników.</p>'}</div><div><h4>Sposób przygotowania</h4><p class="instructions">${r.instructions?esc(r.instructions).replace(/\n/g,'<br>'):'Brak opisu przygotowania.'}</p></div></div></details>`}

function renderPlan(){
  const list=[...state.data.dietPlan].sort((a,b)=>a.date.localeCompare(b.date)||(a.time||'').localeCompare(b.time||''));
  const groups=Object.groupBy?Object.groupBy(list,x=>x.date):list.reduce((a,x)=>((a[x.date]??=[]).push(x),a),{});
  const today=new Date().toISOString().slice(0,10);
  state.selectedPlanDate=state.selectedPlanDate||today;
  $('#plan').innerHTML=`<div class="section-head"><h2>Plan diety</h2><div class="section-actions"><button class="secondary" data-action="toggle-plan-view">${state.planMode==='week'?'Widok listy':'Widok tygodnia'}</button><button class="secondary" data-action="copy-previous-day">Kopiuj poprzedni dzień</button><button class="secondary" data-action="copy-day-many">Kopiuj dzień na daty</button><button class="secondary" data-action="copy-previous-week">Kopiuj poprzedni tydzień</button><button class="secondary" data-action="templates">Szablony</button><button class="secondary" data-action="export-pdf">PDF</button><button class="primary" data-action="quick-add-meal">+ Szybko dodaj</button></div></div>${state.planMode==='week'?weeklyPlanHtml(list):`<div class="list">${Object.keys(groups).length?Object.entries(groups).map(([date,items])=>`<div class="panel day-panel"><div class="day-heading"><div><h3>${new Date(date+'T12:00:00').toLocaleDateString('pl-PL',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</h3>${dayCompletenessHtml(date,items)}</div><button class="secondary" data-day-details="${date}">Szczegóły dnia</button></div>${daySummaryHtml(items)}${planWarnings(items)}${items.map(mealHtml).join('')}<button class="secondary quick-day-add" data-quick-add-date="${date}">+ Szybko dodaj posiłek</button></div>`).join(''):empty('Plan diety jest pusty.','quick-add-meal','Dodaj pierwszy posiłek')}</div>`}`;
}

function renderProducts(){const q=(state.productSearch||'').trim().toLowerCase();const list=state.data.products.filter(p=>p.name.toLowerCase().includes(q)||(p.category||'').toLowerCase().includes(q)).sort((a,b)=>a.name.localeCompare(b.name));$('#products').innerHTML=`${head('Produkty','add-product')}<div class="toolbar search-toolbar"><input id="productSearch" type="search" autocomplete="off" placeholder="Szukaj po nazwie lub kategorii…" value="${esc(state.productSearch)}"><button type="button" class="secondary ${state.productSearch?'':'hidden'}" id="clearProductSearch">Wyczyść</button></div><div class="search-result-info">${q?`Znaleziono: ${list.length}`:`Wszystkie produkty: ${list.length}`}</div><div class="list">${list.length?list.map(p=>`<article class="item"><div><h3>${esc(p.name)} ${p.pantry?'<span class="badge">Mam w domu</span>':''}</h3><p>${esc(p.category||'Inne')} · ${fmt(p.kcal)} kcal · B ${fmt(p.protein)} g · T ${fmt(p.fat)} g · W ${fmt(p.carbs)} g / 100 ${esc(p.baseUnit||'g')}</p>${p.packageSize?`<p>Opakowanie: ${fmt(p.packageSize)} ${esc(p.baseUnit)} · ${fmt(p.packagePrice)} zł</p>`:''}</div><div class="item-actions"><button class="icon-btn" data-edit-product="${p.id}" title="Edytuj">✎</button><button class="icon-btn danger" data-delete-product="${p.id}" title="Usuń" aria-label="Usuń"><span aria-hidden="true">🗑</span></button></div></article>`).join(''):empty(q?'Brak produktów pasujących do wyszukiwania.':'Nie ma jeszcze produktów.')}</div>`;const input=$('#productSearch');input?.addEventListener('input',e=>{state.productSearch=e.target.value;renderProducts();const next=$('#productSearch');if(next){next.focus();next.setSelectionRange(next.value.length,next.value.length)}});$('#clearProductSearch')?.addEventListener('click',()=>{state.productSearch='';renderProducts();$('#productSearch')?.focus()})}

function recipeUsageStats(recipeId){const meals=(state.data.dietPlan||[]).filter(m=>m.recipeId===recipeId).sort((a,b)=>a.date.localeCompare(b.date));return {count:meals.length,last:meals.at(-1)?.date||''}}
function renderRecipes(){
  const q=(state.recipeSearch||'').toLowerCase();
  const collections=[...new Set(state.data.recipes.map(r=>r.collection).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
  let list=[...state.data.recipes].filter(r=>(!q||r.name.toLowerCase().includes(q)||(r.tags||[]).join(' ').toLowerCase().includes(q)||(r.collection||'').toLowerCase().includes(q))&&(state.recipeFilter!=='favorite'||r.favorite)&&(state.recipeCollection==='all'||r.collection===state.recipeCollection)).sort((a,b)=>a.name.localeCompare(b.name));
  $('#recipes').innerHTML=`${head('Przepisy','add-recipe')}<div class="toolbar recipe-toolbar"><input id="recipesSearch" type="search" placeholder="Szukaj nazwy, tagu lub kolekcji…" value="${esc(state.recipeSearch)}"><select id="recipeFilter"><option value="all">Wszystkie</option><option value="favorite" ${state.recipeFilter==='favorite'?'selected':''}>Ulubione</option></select><select id="recipeCollection"><option value="all">Wszystkie kolekcje</option>${collections.map(c=>`<option value="${esc(c)}" ${state.recipeCollection===c?'selected':''}>${esc(c)}</option>`).join('')}</select></div><div class="list">${list.length?list.map(r=>{const n=recipeNutrition(r),u=recipeUsageStats(r.id);return `<article class="item recipe-card"><div class="item-main"><div class="recipe-meta-line"><span class="badge">${esc(r.mealType||'Inne')}</span>${r.collection?`<span class="badge subtle">${esc(r.collection)}</span>`:''}${r.favorite?' <span aria-label="Ulubiony">★</span>':''}</div><h3>${esc(r.name)}</h3><p>${fmt(n.kcal)} kcal · B ${fmt(n.protein)} g · T ${fmt(n.fat)} g · W ${fmt(n.carbs)} g</p><p>${r.prepTime?`${r.prepTime} min · `:''}${esc(r.difficulty||'Łatwy')} ${(r.tags||[]).length?'· '+esc(r.tags.join(', ')):''}</p><div class="usage-stats"><span>Użyty: <b>${u.count}</b> razy</span><span>Ostatnio: <b>${u.last?new Date(u.last+'T12:00').toLocaleDateString('pl-PL'):'nigdy'}</b></span></div>${recipeDetailsHtml(r)}</div><div class="item-actions"><button class="icon-btn" data-cook-days="${r.id}" title="Gotuj na kilka dni" aria-label="Gotuj na kilka dni">▦</button><button class="icon-btn" data-toggle-favorite="${r.id}">${r.favorite?'★':'☆'}</button><button class="icon-btn" data-duplicate-recipe="${r.id}" title="Duplikuj">⧉</button><button class="icon-btn" data-edit-recipe="${r.id}" title="Edytuj">✎</button><button class="icon-btn danger" data-delete-recipe="${r.id}" title="Usuń" aria-label="Usuń"><span aria-hidden="true">🗑</span></button></div></article>`}).join(''):empty('Brak pasujących przepisów.')}</div>`;
  $('#recipesSearch').oninput=e=>{const cursor=e.target.selectionStart??e.target.value.length;state.recipeSearch=e.target.value;renderRecipes();requestAnimationFrame(()=>{const input=$('#recipesSearch');if(input){input.focus();const pos=Math.min(cursor,input.value.length);input.setSelectionRange(pos,pos)}})};
  $('#recipeFilter').onchange=e=>{state.recipeFilter=e.target.value;renderRecipes()};
  $('#recipeCollection').onchange=e=>{state.recipeCollection=e.target.value;renderRecipes()}
}

function renderSettings(){const s=state.data.settings||{},t=s.targets||{},times=s.mealTimes||{};$('#settings').innerHTML=`${head('Ustawienia i dane')}<div class="settings-grid"><div class="panel"><h3>Cele dzienne</h3><div class="form-grid"><label>Kalorie<input id="goalKcal" type="number" value="${t.kcal||2100}"></label><label>Białko (g)<input id="goalProtein" type="number" value="${t.protein||140}"></label><label>Tłuszcz (g)<input id="goalFat" type="number" value="${t.fat||70}"></label><label>Węglowodany (g)<input id="goalCarbs" type="number" value="${t.carbs||230}"></label></div><button class="primary" data-action="save-settings">Zapisz ustawienia</button></div><div class="panel"><h3>Godziny posiłków</h3><div class="form-grid">${Object.keys(MEAL_TIME_SUGGESTIONS).map(k=>`<label>${k}<input type="time" data-meal-time="${esc(k)}" value="${times[k]||MEAL_TIME_SUGGESTIONS[k]}"></label>`).join('')}</div></div><div class="panel"><h3>Wygląd</h3><select id="themeSelect"><option value="system">Systemowy</option><option value="light" ${s.theme==='light'?'selected':''}>Jasny</option><option value="dark" ${s.theme==='dark'?'selected':''}>Ciemny</option></select></div><div class="panel"><h3>Kopie i przywracanie</h3><p>Automatycznie przechowujemy 5 ostatnich wersji.</p><select id="backupSelect">${(state.data.backups||[]).map((b,i)=>`<option value="${i}">${new Date(b.at).toLocaleString('pl-PL')}</option>`).join('')}</select><button class="secondary" data-action="restore-backup">Przywróć wybraną</button></div><div class="panel"><h3>Eksport</h3><button class="primary" data-action="export-pdf">PDF</button> <button class="secondary" data-action="export-excel">Excel</button> <button class="secondary" data-action="export-json">JSON</button><label class="file-label">Importuj Excel<input type="file" id="excelImport" accept=".xlsx,.xls"></label><label class="file-label">Importuj JSON<input type="file" id="jsonImport" accept=".json"></label></div><div class="panel"><h3>Usuń wszystko</h3><button class="danger-btn" data-action="clear-all">Wyczyść dane</button></div></div>`}

function renderShopping(){const items=state.data.shoppingList||[];const groups=shoppingGroups();const bought=items.filter(x=>x.purchased).length;const today=new Date().toISOString().slice(0,10);const end=new Date(Date.now()+6*86400000).toISOString().slice(0,10);const totalCost=items.filter(x=>!x.purchased).reduce((a,x)=>a+num(x.estimatedCost),0);$('#shopping').innerHTML=`${head('Koszyk zakupowy','add-shopping','Dodaj pozycję')}<div class="panel shopping-generator"><h3>Generuj z planu diety</h3><div class="form-grid"><label>Od daty<input id="shoppingFrom" type="date" value="${today}"></label><label>Do daty<input id="shoppingTo" type="date" value="${end}"></label></div><div class="range-presets"><button type="button" class="secondary" data-shopping-preset="1">Dziś</button><button type="button" class="secondary" data-shopping-preset="3">3 dni</button><button type="button" class="secondary" data-shopping-preset="7">7 dni</button><button type="button" class="secondary" data-shopping-preset="14">14 dni</button></div><div class="form-actions"><button class="danger-btn" data-action="clear-shopping">Usuń cały koszyk</button><button class="secondary" data-action="clear-purchased">Usuń kupione</button><button class="primary" data-action="generate-shopping">Generuj listę</button></div></div><div class="shopping-summary"><span>${items.length} pozycji</span><span>${bought} kupionych</span><span>${items.length-bought} do kupienia</span><span>Szacowany koszt: ${fmt(totalCost)} zł</span></div><div class="shopping-sections">${Object.keys(groups).length?Object.entries(groups).map(([cat,list])=>`<section class="panel shopping-category"><h3>${esc(cat)}</h3><div class="shopping-table">${list.map(x=>{const p=productById(x.productId),packageSize=num(p?.packageSize),packages=packageSize?Math.ceil(num(x.amount)/packageSize):0,remaining=packages&&packageSize?packages*packageSize-num(x.amount):0,cost=num(x.estimatedCost);return `<div class="shopping-row ${x.purchased?'purchased':''}"><label class="shopping-check"><input type="checkbox" data-toggle-shopping="${x.id}" ${x.purchased?'checked':''}><span></span></label><div class="shopping-name"><strong>${esc(x.name)}</strong><small>Potrzebne: ${fmt(x.amount)} ${esc(x.unit||'g')}${x.source==='plan'?' · z planu':''}</small>${packages?`<small class="package-info">Kup: ${packages} × ${fmt(packageSize)} ${esc(x.unit||p?.baseUnit||'g')}${remaining>0?` · zostanie ${fmt(remaining)} ${esc(x.unit||p?.baseUnit||'g')}`:''}${cost?` · ok. ${fmt(cost)} zł`:''}</small>`:''}</div><div class="item-actions"><button class="icon-btn" data-edit-shopping="${x.id}">✎</button><button class="icon-btn danger" data-delete-shopping="${x.id}">×</button></div></div>`}).join('')}</div></section>`).join(''):empty('Koszyk jest pusty. Wygeneruj listę z planu albo dodaj pozycję ręcznie.')}</div>`}

function sheetFromRows(rows,widths=[]){const X=ensureXlsx();const ws=X.utils.json_to_sheet(rows);if(widths.length)ws['!cols']=widths.map(w=>({wch:w}));return ws}

function shoppingForm(item){openModal(item?'Edytuj pozycję':'Dodaj do koszyka',`<div class="form-grid"><label class="full">Nazwa<input name="name" required value="${esc(item?.name||'')}"></label><label>Ilość<input name="amount" type="number" step="0.1" min="0" required value="${item?.amount??''}"></label><label>Jednostka<select name="unit">${['g','kg','ml','l','szt.','opak.'].map(x=>`<option ${item?.unit===x?'selected':''}>${x}</option>`).join('')}</select></label><label class="full">Kategoria<select name="category">${SHOP_CATEGORIES.map(x=>`<option ${item?.category===x?'selected':''}>${x}</option>`).join('')}</select></label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zapisz</button></div>`,async fd=>{const x={id:item?.id||uid(),productId:item?.productId||'',name:fd.get('name').trim(),amount:num(fd.get('amount')),unit:fd.get('unit'),category:fd.get('category'),purchased:item?.purchased||false,source:item?.source||'manual'};item?Object.assign(item,x):state.data.shoppingList.push(x);closeModal();await save()})}

function shoppingGroups(){const items=[...(state.data.shoppingList||[])].sort((a,b)=>(a.purchased-b.purchased)||(a.category||'Inne').localeCompare(b.category||'Inne')||a.name.localeCompare(b.name));return items.reduce((g,x)=>((g[x.category||'Inne']??=[]).push(x),g),{})}

function renderDashboard(){
  const d=state.data;const today=new Date().toISOString().slice(0,10);const meals=d.dietPlan.filter(x=>x.date===today).sort((a,b)=>(a.time||'').localeCompare(b.time||''));
  const n=mealsNutrition(meals),targets=d.settings?.targets||{};const now=new Date().toTimeString().slice(0,5);const next=meals.find(m=>(m.time||'')>=now)||meals[0];const nextRecipe=next?recipeById(next.recipeId):null;
  $('#dashboard').innerHTML=`<div class="welcome-head"><div><span class="eyebrow">Dzisiaj</span><h2>${new Date(today+'T12:00').toLocaleDateString('pl-PL',{weekday:'long',day:'numeric',month:'long'})}</h2></div><button class="primary" data-action="add-meal">+ Dodaj posiłek</button></div>
  <div class="today-hero panel"><div class="calorie-ring"><strong>${fmt(n.kcal)}</strong><span>z ${fmt(targets.kcal||2100)} kcal</span></div><div class="today-main"><h3>${meals.length?`${meals.length} zaplanowane posiłki`:'Brak planu na dziś'}</h3><p>${next&&nextRecipe?`Następny: <b>${esc(next.mealType)}</b> o ${esc(next.time||'--:--')}<br>${esc(nextRecipe.name)}`:'Dodaj pierwszy posiłek lub skopiuj wczorajszy dzień.'}</p>${goalBarsCompact(n,targets)}</div></div>
  <div class="quick-actions compact-actions"><button class="secondary" data-action="copy-previous-day">↺ Skopiuj wczoraj</button><button class="secondary" data-action="add-measurement">＋ Pomiar</button><button class="secondary" data-action="generate-shopping">▣ Wygeneruj zakupy</button></div>
  <div class="dashboard-grid"><section class="panel"><div class="panel-title"><h3>Dzisiejszy plan</h3><button class="text-btn" data-nav="plan">Zobacz plan →</button></div>${meals.length?meals.map(mealHtml).join(''):empty('Nie masz jeszcze posiłków na dziś','add-meal','Dodaj posiłek')}</section><section class="panel"><div class="panel-title"><h3>Postępy</h3><button class="text-btn" data-nav="measurements">Pomiary →</button></div>${measurementChartHtml()}</section></div>`
}
function goalBarsCompact(n,t){const row=(l,v,max,u)=>`<div><span>${l}</span><progress max="${max||1}" value="${Math.min(v,max||1)}"></progress><b>${fmt(v)} / ${fmt(max)} ${u}</b></div>`;return `<div class="compact-goals">${row('Białko',n.protein,num(t.protein),'g')}${row('Tłuszcz',n.fat,num(t.fat),'g')}${row('Węglowodany',n.carbs,num(t.carbs),'g')}</div>`}

function rowsFromSheet(wb,name){const X=ensureXlsx();const ws=wb.Sheets[name];return ws?X.utils.sheet_to_json(ws,{defval:'',raw:false}):[]}
function cell(row,...names){for(const n of names){if(row[n]!==undefined&&row[n]!==null&&String(row[n]).trim()!=='')return row[n]}return ''}
function excelNumber(v){if(v===''||v===null||v===undefined)return 0;return Number(String(v).replace(',','.'))||0}
function excelDate(v){if(!v)return '';const text=String(v).trim();if(/^\d{4}-\d{2}-\d{2}$/.test(text))return text;const m=text.match(/^(\d{1,2})[.\/-](\d{1,2})[.\/-](\d{4})$/);if(m)return `${m[3]}-${m[2].padStart(2,'0')}-${m[1].padStart(2,'0')}`;const d=new Date(text);return Number.isNaN(d.getTime())?'':d.toISOString().slice(0,10)}
async function importExcel(file){
  const X=ensureXlsx();const wb=X.read(await file.arrayBuffer(),{type:'array',cellDates:true});
  const productRows=rowsFromSheet(wb,'Produkty'),recipeRows=rowsFromSheet(wb,'Przepisy'),ingredientRows=rowsFromSheet(wb,'Skladniki'),planRows=rowsFromSheet(wb,'Plan_diety'),shoppingRows=rowsFromSheet(wb,'Lista_zakupow'),measurementRows=rowsFromSheet(wb,'Pomiary');
  if(!productRows.length&&!recipeRows.length&&!planRows.length&&!measurementRows.length)throw Error('Brak obsługiwanych arkuszy');
  const products=productRows.filter(r=>String(cell(r,'Nazwa','Produkt')).trim()).map(r=>({id:String(cell(r,'ID')||uid()),name:String(cell(r,'Nazwa','Produkt')).trim(),kcal:excelNumber(cell(r,'Kalorie_100g','Kalorie','kcal')),protein:excelNumber(cell(r,'Bialko_100g','Bialko')),fat:excelNumber(cell(r,'Tluszcz_100g','Tluszcz')),carbs:excelNumber(cell(r,'Weglowodany_100g','Weglowodany')),category:normalizeCategory(String(cell(r,'Kategoria')||'').trim(),String(cell(r,'Nazwa','Produkt')).trim(),true),baseUnit:String(cell(r,'Jednostka_bazowa')||'g')==='ml'?'ml':'g',conversions:(()=>{try{return JSON.parse(String(cell(r,'Przeliczniki_JSON')||'{}'))}catch{return {}}})()}));
  const productByExcelId=new Map(products.map(p=>[p.id,p]));const productByName=new Map(products.map(p=>[p.name.toLowerCase(),p]));
  const recipes=recipeRows.filter(r=>String(cell(r,'Nazwa','Przepis')).trim()).map(r=>({id:String(cell(r,'ID')||uid()),name:String(cell(r,'Nazwa','Przepis')).trim(),mealType:String(cell(r,'Typ_posilku','Typ posilku')||'Inne').trim(),collection:String(cell(r,'Kolekcja')||'').trim(),tags:String(cell(r,'Tagi')||'').split(',').map(x=>x.trim()).filter(Boolean),prepTime:excelNumber(cell(r,'Czas_przygotowania'))||0,difficulty:String(cell(r,'Trudnosc')||'Łatwy'),instructions:String(cell(r,'Przygotowanie','Sposob przygotowania')||'').trim(),ingredients:[]}));
  const recipeByExcelId=new Map(recipes.map(r=>[r.id,r]));const recipeByName=new Map(recipes.map(r=>[r.name.toLowerCase(),r]));
  for(const row of ingredientRows){const recipe=recipeByExcelId.get(String(cell(row,'ID_przepisu')))||recipeByName.get(String(cell(row,'Nazwa_przepisu')).trim().toLowerCase());const product=productByExcelId.get(String(cell(row,'ID_produktu')))||productByName.get(String(cell(row,'Nazwa_produktu')).trim().toLowerCase());const amount=excelNumber(cell(row,'Ilosc','Ilosc_g'));const unit=String(cell(row,'Jednostka')||product?.baseUnit||'g');const baseAmount=excelNumber(cell(row,'Ilosc_bazowa'))||amount*unitFactor(product,unit);if(recipe&&product&&amount>0)recipe.ingredients.push({productId:product.id,amount,unit,baseAmount,grams:baseAmount})}
  const dietPlan=planRows.filter(r=>excelDate(cell(r,'Data'))).map(r=>{const recipe=recipeByExcelId.get(String(cell(r,'ID_przepisu')))||recipeByName.get(String(cell(r,'Nazwa_przepisu')).trim().toLowerCase());return {id:String(cell(r,'ID')||uid()),date:excelDate(cell(r,'Data')),time:String(cell(r,'Godzina')||''),mealType:String(cell(r,'Typ_posilku','Typ posilku')||recipe?.mealType||'Inne'),recipeId:recipe?.id||'',portions:Math.max(0.25,excelNumber(cell(r,'Liczba_porcji','Porcje'))||1)}}).filter(x=>x.recipeId);
  const shoppingList=shoppingRows.filter(r=>String(cell(r,'Nazwa')).trim()).map(r=>({id:String(cell(r,'ID')||uid()),productId:'',name:String(cell(r,'Nazwa')).trim(),amount:excelNumber(cell(r,'Ilosc')),unit:String(cell(r,'Jednostka')||'g'),category:normalizeCategory(String(cell(r,'Kategoria')||'').trim(),String(cell(r,'Nazwa')).trim(),true),purchased:String(cell(r,'Kupione')).toUpperCase()==='TAK',source:String(cell(r,'Zrodlo')||'manual')}));
  const measurements=measurementRows.filter(r=>excelDate(cell(r,'Data'))).map(r=>({id:String(cell(r,'ID')||uid()),date:excelDate(cell(r,'Data')),weight:excelNumber(cell(r,'Masa_kg','Masa'))||null,waist:excelNumber(cell(r,'Talia_cm','Talia'))||null,chest:excelNumber(cell(r,'Klatka_cm','Klatka'))||null,notes:String(cell(r,'Notatki')||'').trim()}));
  if(!await confirmDialog({title:'Zaimportować dane z Excela?',message:`Produkty: ${products.length}
Przepisy: ${recipes.length}
Plan: ${dietPlan.length}
Koszyk: ${shoppingList.length}
Pomiary: ${measurements.length}

Aktualne dane zostaną zastąpione.`,confirmLabel:'Importuj'}))return;
  state.data={version:8,updatedAt:null,products,recipes,dietPlan,measurements,shoppingList,settings:state.data.settings||{},dayTemplates:[],backups:[]};await save();toast('Dane z Excela zostały zaimportowane');
}

const actions={
'open-more':()=>openMore(), 'close-more':()=>closeMore(),
'add-product':()=>productForm(), 'add-recipe':()=>recipeForm(), 'add-meal':()=>mealForm(),'quick-add-meal':()=>quickMealForm({date:state.selectedPlanDate||new Date().toISOString().slice(0,10)}), 'add-shopping':()=>shoppingForm(), 'add-measurement':()=>measurementForm(),
'export-pdf':()=>pdfExportForm(),
'copy-previous-day':()=>copyPreviousDayForm(),
'copy-previous-week':()=>copyPreviousWeek(),
'copy-day-many':()=>copyDayToDatesForm(),
'previous-week':()=>{state.planWeekStart=shiftIsoDate(state.planWeekStart||weekStart(),-7);renderPlan()},
'next-week':()=>{state.planWeekStart=shiftIsoDate(state.planWeekStart||weekStart(),7);renderPlan()},
'current-week':()=>{state.planWeekStart=weekStart();renderPlan()},
'toggle-plan-view':()=>{state.planMode=state.planMode==='week'?'list':'week';renderPlan()},
'templates':()=>templatesForm(),
'save-settings':async()=>{state.data.settings.targets={kcal:num($('#goalKcal')?.value),protein:num($('#goalProtein')?.value),fat:num($('#goalFat')?.value),carbs:num($('#goalCarbs')?.value)};state.data.settings.mealTimes={...MEAL_TIME_SUGGESTIONS};$$('[data-meal-time]').forEach(x=>state.data.settings.mealTimes[x.dataset.mealTime]=x.value);state.data.settings.theme=$('#themeSelect')?.value||'system';await save()},
'restore-backup':async()=>{const b=state.data.backups?.[num($('#backupSelect')?.value)];if(b&&await confirmDialog({title:'Przywrócić kopię?',message:'Aktualne dane zostaną zastąpione wybraną wersją.',confirmLabel:'Przywróć'})){Object.assign(state.data,b.data);await save()}},
'generate-shopping':()=>generateShopping(), 'clear-shopping':async()=>{const count=(state.data.shoppingList||[]).length;if(!count)return toast('Koszyk jest już pusty');if(await confirmDialog({title:'Usunąć cały koszyk?',message:`Zostanie usuniętych pozycji: ${count}`,confirmLabel:'Usuń koszyk',danger:true})){state.data.shoppingList=[];await save();toast('Cały koszyk został usunięty')}}, 'clear-purchased':async()=>{state.data.shoppingList=(state.data.shoppingList||[]).filter(x=>!x.purchased);await save()},
'export-excel':()=>exportExcel(),
'export-json':()=>{const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(state.data,null,2)],{type:'application/json'}));a.download=`moja-dieta-${new Date().toISOString().slice(0,10)}.json`;a.click();URL.revokeObjectURL(a.href)},
'seed':async()=>{if(state.data.products.length&&!await confirmDialog({title:'Dodać dane demonstracyjne?',message:'Dane zostaną dodane do istniejących produktów i przepisów.',confirmLabel:'Dodaj'}))return;const p1={id:uid(),name:'Płatki owsiane',category:'Produkty zbożowe',kcal:370,protein:13,fat:7,carbs:60,baseUnit:'g',conversions:{'szklanka':90,'łyżka':10}},p2={id:uid(),name:'Banan',category:'Warzywa i owoce',kcal:89,protein:1.1,fat:.3,carbs:23,baseUnit:'g',conversions:{'sztuka':120}},p3={id:uid(),name:'Migdały',category:'Przetwory i suche produkty',kcal:579,protein:21,fat:50,carbs:22,baseUnit:'g',conversions:{'łyżka':15,'garść':25}};state.data.products.push(p1,p2,p3);state.data.recipes.push({id:uid(),name:'Owsianka z bananem i migdałami',mealType:'Śniadanie',instructions:'Płatki zalej gorącą wodą. Dodaj banana i posiekane migdały.',ingredients:[{productId:p1.id,amount:60,unit:'g',baseAmount:60,grams:60},{productId:p2.id,amount:1,unit:'sztuka',baseAmount:120,grams:120},{productId:p3.id,amount:20,unit:'g',baseAmount:20,grams:20}]});await save()},
'clear-all':async()=>{if(await confirmDialog({title:'Usunąć wszystkie dane?',message:'Produkty, przepisy, plan, koszyk i pomiary zostaną trwale usunięte.',confirmLabel:'Usuń wszystko',danger:true})){state.data={version:8,updatedAt:null,products:[],recipes:[],dietPlan:[],measurements:[],shoppingList:[],settings:{targets:{kcal:2100,protein:140,fat:70,carbs:230},mealTimes:{...MEAL_TIME_SUGGESTIONS},theme:'system'},dayTemplates:[],backups:[]};await save()}}
};
function conversionFields(p={}){return COMMON_UNITS.map(u=>`<label>${u} = ile ${p.baseUnit||'g'}?<input name="conv_${u}" type="number" min="0" step="0.1" value="${p.conversions?.[u]??''}" placeholder="opcjonalnie"></label>`).join('')}
function fieldsProduct(p={}){p=normalizeProductUnits(p);return `<div class="form-grid"><label class="full">Nazwa<input name="name" required value="${esc(p.name||'')}"></label><label>Kategoria<select name="category">${SHOP_CATEGORIES.map(x=>`<option ${p.category===x?'selected':''}>${x}</option>`).join('')}</select></label><label>Jednostka bazowa<select name="baseUnit"><option value="g" ${p.baseUnit==='g'?'selected':''}>g</option><option value="ml" ${p.baseUnit==='ml'?'selected':''}>ml</option></select></label><label><input name="pantry" type="checkbox" ${p.pantry?'checked':''}> Mam w domu</label><label>Wielkość opakowania<input name="packageSize" type="number" step="0.1" value="${p.packageSize||''}"></label><label>Cena opakowania (zł)<input name="packagePrice" type="number" step="0.01" value="${p.packagePrice||''}"></label><label>Kalorie / 100<input name="kcal" type="number" step="0.1" value="${p.kcal??''}"></label><label>Białko / 100<input name="protein" type="number" step="0.1" value="${p.protein??''}"></label><label>Tłuszcz / 100<input name="fat" type="number" step="0.1" value="${p.fat??''}"></label><label>Węglowodany / 100<input name="carbs" type="number" step="0.1" value="${p.carbs??''}"></label><div class="full"><h4>Jednostki domowe</h4><div class="form-grid">${conversionFields(p)}</div></div></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zapisz</button></div>`}
function productForm(p){openModal(p?'Edytuj produkt':'Dodaj produkt',fieldsProduct(p),async fd=>{const conversions={};for(const u of COMMON_UNITS){const v=num(fd.get(`conv_${u}`));if(v>0)conversions[u]=v}const x={id:p?.id||uid(),name:fd.get('name').trim(),kcal:num(fd.get('kcal')),protein:num(fd.get('protein')),fat:num(fd.get('fat')),carbs:num(fd.get('carbs')),category:normalizeCategory(fd.get('category'),fd.get('name')),baseUnit:fd.get('baseUnit')==='ml'?'ml':'g',conversions,pantry:fd.get('pantry')==='on',packageSize:num(fd.get('packageSize')),packagePrice:num(fd.get('packagePrice'))};p?Object.assign(p,x):state.data.products.push(x);closeModal();await save()})}
const RECIPE_DRAFT_PREFIX='diet-recipe-draft-';
function recipeDraftKey(r){return RECIPE_DRAFT_PREFIX+(r?.id||'new')}
function collectRecipeDraft(form=$('#modalForm')){if(!form)return null;const productIds=[...form.querySelectorAll('[name="productId"]')].map(x=>x.value),amounts=[...form.querySelectorAll('[name="ingredientAmount"]')].map(x=>x.value),units=[...form.querySelectorAll('[name="ingredientUnit"]')].map(x=>x.value);return {name:form.elements.name?.value||'',mealType:form.elements.mealType?.value||'Śniadanie',favorite:!!form.elements.favorite?.checked,prepTime:form.elements.prepTime?.value||'',difficulty:form.elements.difficulty?.value||'Łatwy',tags:form.elements.tags?.value||'',collection:form.elements.collection?.value||'',notes:form.elements.notes?.value||'',instructions:form.elements.instructions?.value||'',ingredients:productIds.map((productId,i)=>({productId,amount:amounts[i],unit:units[i]})),savedAt:new Date().toISOString()}}
function saveRecipeDraft(key){const draft=collectRecipeDraft();if(draft)localStorage.setItem(key,JSON.stringify(draft))}
function clearRecipeDraft(key){localStorage.removeItem(key)}
function recipeStep(step){$$('.recipe-step').forEach(x=>x.classList.toggle('active',num(x.dataset.step)===step));$$('.recipe-step-tab').forEach(x=>{x.classList.toggle('active',num(x.dataset.stepTarget)===step);x.setAttribute('aria-current',num(x.dataset.stepTarget)===step?'step':'false')});const back=$('#recipeBack'),next=$('#recipeNext'),save=$('#recipeSave');if(back)back.hidden=step===1;if(next)next.hidden=step===3;if(save)save.hidden=step!==3;const modal=$('#modal');if(modal)modal.dataset.recipeStep=String(step);$('#modalForm')?.querySelector('.recipe-step.active input,.recipe-step.active select,.recipe-step.active textarea')?.focus()}
function fieldError(el,message=''){const label=el?.closest('label,.field-wrap');if(!label)return;label.classList.toggle('field-invalid',!!message);let help=label.querySelector('.field-error');if(message){if(!help){help=document.createElement('small');help.className='field-error';label.appendChild(help)}help.textContent=message}else help?.remove()}
function validateRecipeStep(step){const form=$('#modalForm');let ok=true;if(step===1){const name=form.elements.name;fieldError(name);if(!name.value.trim()){fieldError(name,'Wpisz nazwę przepisu.');ok=false}const prep=form.elements.prepTime;fieldError(prep);if(prep.value&&num(prep.value)<0){fieldError(prep,'Czas nie może być ujemny.');ok=false}}if(step===2){const rows=[...form.querySelectorAll('.ingredient-picker')];if(!rows.length){toast('Dodaj co najmniej jeden składnik');ok=false}rows.forEach(row=>{const product=row.querySelector('[name="productId"]'),amount=row.querySelector('[name="ingredientAmount"]');fieldError(product);fieldError(amount);if(!product.value){fieldError(product,'Wybierz produkt.');ok=false}if(!(num(amount.value)>0)){fieldError(amount,'Podaj ilość większą od zera.');ok=false}})}if(step===3){const instructions=form.elements.instructions;fieldError(instructions);if(!instructions.value.trim()){fieldError(instructions,'Dodaj krótki sposób przygotowania.');ok=false}}return ok}
async function recipeForm(r){const key=recipeDraftKey(r);let source=r?{...r,tags:(r.tags||[]).join(', ')}:{mealType:'Śniadanie',difficulty:'Łatwy',ingredients:[{productId:'',amount:'',unit:'g'}]};const raw=localStorage.getItem(key);if(raw){try{const draft=JSON.parse(raw);const restore=await confirmDialog({title:'Przywrócić szkic?',message:`Znaleziono niezapisany szkic z ${new Date(draft.savedAt).toLocaleString('pl-PL')}.`,confirmLabel:'Przywróć'});if(restore)source=draft;else clearRecipeDraft(key)}catch{clearRecipeDraft(key)}}const ingredients=source.ingredients?.length?source.ingredients:[{productId:'',amount:'',unit:'g'}];const rows=ingredients.map((i,idx)=>ingredientRow(i,idx)).join('');openModal(r?'Edytuj przepis':'Dodaj przepis',`<div class="recipe-wizard"><div class="recipe-stepper" role="tablist"><button type="button" class="recipe-step-tab active" data-step-target="1"><span>1</span>Informacje</button><button type="button" class="recipe-step-tab" data-step-target="2"><span>2</span>Składniki</button><button type="button" class="recipe-step-tab" data-step-target="3"><span>3</span>Przygotowanie</button></div><section class="recipe-step active" data-step="1"><div class="form-grid"><label class="full">Nazwa przepisu <span class="required-mark">*</span><input name="name" required maxlength="120" value="${esc(source.name||'')}" placeholder="np. Owsianka z bananem"><small class="field-help">Krótka nazwa, po której łatwo znajdziesz przepis.</small></label><label>Typ posiłku<select name="mealType">${['Śniadanie','II śniadanie','Obiad','Podwieczorek','Kolacja','Przekąska','Inne'].map(x=>`<option ${source.mealType===x?'selected':''}>${x}</option>`).join('')}</select></label><label>Czas przygotowania (min)<input name="prepTime" type="number" min="0" step="1" value="${source.prepTime||''}" placeholder="np. 20"></label><label>Trudność<select name="difficulty">${['Łatwy','Średni','Trudny'].map(x=>`<option ${source.difficulty===x?'selected':''}>${x}</option>`).join('')}</select></label><label class="checkbox-field"><input name="favorite" type="checkbox" ${source.favorite?'checked':''}> Dodaj do ulubionych</label><label class="full">Tagi<input name="tags" value="${esc(Array.isArray(source.tags)?source.tags.join(', '):(source.tags||''))}" placeholder="szybkie, do pracy, bez glutenu"><small class="field-help">Oddziel tagi przecinkami.</small></label><label class="full">Kolekcja<input name="collection" value="${esc(source.collection||'')}" placeholder="np. Do pracy, Na 2 dni, Szybkie kolacje"><small class="field-help">Kolekcja grupuje przepisy w większe zestawy.</small></label></div></section><section class="recipe-step" data-step="2"><div class="ingredient-section-head"><div><h3>Składniki</h3><p>Wybierz produkt, wpisz ilość i jednostkę. Przeliczenie pokaże się automatycznie.</p></div><button type="button" class="secondary" id="addIngredient">+ Dodaj składnik</button></div><div id="ingredientRows" class="ingredient-rows">${rows}</div><div class="ingredient-empty-help">Nie widzisz produktu? Najpierw dodaj go w sekcji Produkty.</div></section><section class="recipe-step" data-step="3"><div class="form-grid"><label class="full">Sposób przygotowania <span class="required-mark">*</span><textarea name="instructions" rows="9" placeholder="Opisz przygotowanie krok po kroku…">${esc(source.instructions||'')}</textarea></label><label class="full">Własne notatki<textarea name="notes" rows="4" placeholder="Np. następnym razem dodać mniej czosnku">${esc(source.notes||'')}</textarea></label><div class="full recipe-preview" id="recipeDraftSummary"></div></div></section></div><div class="draft-status" id="draftStatus">Szkic zapisuje się automatycznie na tym urządzeniu.</div><div class="form-actions recipe-wizard-actions"><button type="button" class="secondary" data-close>Anuluj</button><button type="button" class="secondary" id="recipeBack" hidden>Wstecz</button><button type="button" class="primary" id="recipeNext">Dalej</button><button type="submit" class="primary" id="recipeSave" hidden>Zapisz przepis</button></div>`,async fd=>{if(!validateRecipeStep(3))return;const productIds=fd.getAll('productId'),amounts=fd.getAll('ingredientAmount'),units=fd.getAll('ingredientUnit');const ingredients=productIds.map((id,i)=>{const p=productById(id),amount=num(amounts[i]),unit=units[i]||p?.baseUnit||'g',baseAmount=amount*unitFactor(p,unit);return {productId:id,amount,unit,baseAmount,grams:baseAmount}}).filter(i=>i.productId&&i.amount>0);if(!ingredients.length){recipeStep(2);toast('Dodaj co najmniej jeden składnik');return}const x={id:r?.id||uid(),name:fd.get('name').trim(),mealType:fd.get('mealType'),instructions:fd.get('instructions').trim(),ingredients,favorite:fd.get('favorite')==='on',prepTime:num(fd.get('prepTime')),difficulty:fd.get('difficulty'),tags:String(fd.get('tags')||'').split(',').map(x=>x.trim()).filter(Boolean),collection:fd.get('collection').trim(),notes:fd.get('notes').trim()};r?Object.assign(r,x):state.data.recipes.push(x);clearRecipeDraft(key);$('#modal').dataset.recipeDirty='false';await closeModal(true);await save()});const modal=$('#modal'),form=$('#modalForm');modal.dataset.modalType='recipe';modal.dataset.recipeDirty='false';modal.dataset.recipeDraftKey=key;let step=1,timer;const markDirty=()=>{modal.dataset.recipeDirty='true';clearTimeout(timer);timer=setTimeout(()=>{saveRecipeDraft(key);const status=$('#draftStatus');if(status)status.textContent=`Szkic zapisany: ${new Date().toLocaleTimeString('pl-PL',{hour:'2-digit',minute:'2-digit'})}`},350)};form.addEventListener('input',markDirty);form.addEventListener('change',markDirty);$('#recipeNext').onclick=()=>{if(!validateRecipeStep(step))return;step=Math.min(3,step+1);recipeStep(step);if(step===3)updateRecipeDraftSummary()};$('#recipeBack').onclick=()=>{step=Math.max(1,step-1);recipeStep(step)};$$('.recipe-step-tab').forEach(btn=>btn.onclick=()=>{const target=num(btn.dataset.stepTarget);if(target>step&&!validateRecipeStep(step))return;step=target;recipeStep(step);if(step===3)updateRecipeDraftSummary()});$('#addIngredient').onclick=()=>{const rows=$('#ingredientRows');rows.insertAdjacentHTML('beforeend',ingredientRow({},Date.now()));rows.lastElementChild?.querySelector('.ingredient-product-search')?.focus();markDirty()};recipeStep(1)}
function updateRecipeDraftSummary(){const d=collectRecipeDraft();const count=(d?.ingredients||[]).filter(i=>i.productId&&num(i.amount)>0).length;const el=$('#recipeDraftSummary');if(el)el.innerHTML=`<h3>Podsumowanie</h3><p><strong>${esc(d?.name||'Bez nazwy')}</strong></p><p>${esc(d?.mealType||'Inne')} · ${d?.prepTime?`${esc(d.prepTime)} min · `:''}${esc(d?.difficulty||'Łatwy')}</p><p>Składniki: ${count}</p>`}
function productOptions(selectedId='',query=''){const q=(query||'').trim().toLowerCase();return [...state.data.products].filter(p=>!q||p.name.toLowerCase().includes(q)||(p.category||'').toLowerCase().includes(q)).sort((a,b)=>a.name.localeCompare(b.name)).map(p=>`<option value="${p.id}" ${selectedId===p.id?'selected':''}>${esc(p.name)} — ${esc(p.category||'Inne')}</option>`).join('')}
function unitOptions(p,selected=''){return availableUnits(p).map(u=>`<option value="${esc(u)}" ${selected===u?'selected':''}>${esc(u)}</option>`).join('')}
function ingredientRow(i,idx){const selectId=`ingredient-product-${idx}-${Math.random().toString(36).slice(2,7)}`,unitId=`ingredient-unit-${idx}-${Math.random().toString(36).slice(2,7)}`;const p=productById(i.productId);const unit=i.unit||p?.baseUnit||'g';const amount=i.amount!=null?i.amount:(p?ingredientBaseAmount(i,p)/unitFactor(p,unit):i.grams||'');const base=amount&&p?num(amount)*unitFactor(p,unit):0;return `<div class="ingredient-picker" data-ingredient-row><div class="ingredient-main"><label class="product-search-field">Produkt <span class="required-mark">*</span><input type="search" class="ingredient-product-search" data-target="${selectId}" autocomplete="off" placeholder="Zacznij wpisywać nazwę…"><select id="${selectId}" name="productId" class="ingredient-product-select" data-unit-target="${unitId}" required><option value="">Wybierz produkt…</option>${productOptions(i.productId||'')}</select></label><label>Ilość <span class="required-mark">*</span><input name="ingredientAmount" type="number" min="0.01" step="0.01" required value="${amount??''}" placeholder="0"></label><label>Jednostka<select id="${unitId}" name="ingredientUnit" class="ingredient-unit-select" required>${p?unitOptions(p,unit):'<option value="g">g</option>'}</select></label><button type="button" class="icon-btn danger ingredient-remove" aria-label="Usuń składnik">🗑</button></div><small class="ingredient-conversion">${base&&p?`${fmt(amount)} ${esc(unit)} = ${fmt(base)} ${esc(p.baseUnit||'g')}`:'Wybierz produkt i ilość, aby zobaczyć przeliczenie.'}</small></div>`}
function mealForm(m){
  const selectedType=m?.mealType||'Śniadanie';
  const initialTime=m?.time||suggestedMealTime(selectedType);
  openModal(m&&!m._new?'Edytuj posiłek':'Dodaj posiłek',`<div class="form-grid"><label>Data<input name="date" type="date" required value="${m?.date||new Date().toISOString().slice(0,10)}"></label><label>Godzina<input name="time" id="mealTime" type="time" value="${initialTime}"><small id="mealTimeHint" class="field-help"></small></label><label>Typ posiłku<select name="mealType" id="mealType">${MEAL_TYPES.map(x=>`<option ${selectedType===x?'selected':''}>${x}</option>`).join('')}</select></label><label>Liczba porcji<input name="portions" id="mealPortions" type="number" min="0.25" max="3" step="0.25" required value="${m?.portions??1}"><small id="portionSuggestion" class="field-help"></small></label><div class="full portion-tools"><button type="button" class="secondary" id="fitRemainingCalories">Dopasuj do kalorii</button><button type="button" class="secondary" id="cookSeveralDaysFromMeal">Zaplanuj na kilka dni</button></div><label class="full">Wyszukaj przepis<input type="search" id="recipeSearch" autocomplete="off" placeholder="Wpisz nazwę przepisu…"></label><label class="full">Przepis<select name="recipeId" id="recipeSelect" required></select><small id="recipeSearchInfo" class="field-help"></small></label><div class="full" id="mealImpactPreview"></div></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zapisz</button></div>`,async fd=>{const x={id:(m&&!m._new?m.id:null)||uid(),date:fd.get('date'),time:fd.get('time'),mealType:fd.get('mealType'),recipeId:fd.get('recipeId'),portions:Math.min(3,Math.max(0.25,num(fd.get('portions'))||1))};m&&!m._new?Object.assign(m,x):state.data.dietPlan.push(x);await closeModal(true);await save()});
  const fill=()=>{const type=$('#mealType').value,q=($('#recipeSearch').value||'').trim().toLowerCase(),select=$('#recipeSelect'),current=select.value||m?.recipeId||'';const rs=state.data.recipes.filter(r=>r.mealType===type&&(!q||r.name.toLowerCase().includes(q))).sort((a,b)=>(b.favorite?1:0)-(a.favorite?1:0)||a.name.localeCompare(b.name));select.innerHTML=`<option value="">Wybierz przepis…</option>${rs.map(r=>`<option value="${r.id}" ${current===r.id?'selected':''}>${r.favorite?'★ ':''}${esc(r.name)}</option>`).join('')}`;$('#recipeSearchInfo').textContent=rs.length?`Dostępne przepisy: ${rs.length}`:'Brak przepisów pasujących do typu i wyszukiwania.';updateMealImpactPreview(m?.id)};
  const timeInput=$('#mealTime'),timeHint=$('#mealTimeHint');let timeChangedManually=Boolean(m?.time);
  const updateSuggestedTime=()=>{const suggestion=suggestedMealTime($('#mealType').value);if(!timeChangedManually)timeInput.value=suggestion;timeHint.textContent=`Sugerowana godzina: ${suggestion}.`};
  timeInput.oninput=()=>{timeChangedManually=true;timeHint.textContent='Godzina ustawiona ręcznie.'};
  $('#mealType').onchange=()=>{if(!m||m._new)timeChangedManually=false;updateSuggestedTime();fill()};
  $('#recipeSearch').oninput=fill;$('#recipeSelect').onchange=()=>updateMealImpactPreview(m?.id);$('#mealPortions').oninput=()=>updateMealImpactPreview(m?.id);$('#modalForm [name=date]').onchange=()=>updateMealImpactPreview(m?.id);
  $('#fitRemainingCalories').onclick=()=>{const recipe=recipeById($('#recipeSelect').value);if(!recipe)return toast('Najpierw wybierz przepis');const date=$('#modalForm [name=date]').value,target=num(state.data.settings?.targets?.kcal)||2100,other=mealsNutrition(state.data.dietPlan.filter(x=>x.date===date&&x.id!==(m?.id||''))).kcal,per=recipeNutrition(recipe).kcal;if(!(per>0))return toast('Przepis nie ma poprawnej kaloryczności');const remaining=Math.max(0,target-other),suggested=Math.min(3,Math.max(.25,Math.round((remaining/per)*4)/4));$('#mealPortions').value=suggested;$('#portionSuggestion').textContent=`Pozostało ok. ${fmt(remaining)} kcal. Sugerowane: ${fmt(suggested)} por.`;updateMealImpactPreview(m?.id)};
  $('#cookSeveralDaysFromMeal').onclick=()=>{const rid=$('#recipeSelect').value;if(!rid)return toast('Najpierw wybierz przepis');cookSeveralDaysForm(recipeById(rid),{startDate:$('#modalForm [name=date]').value,mealType:$('#mealType').value,time:$('#mealTime').value,portions:num($('#mealPortions').value)||1})};updateSuggestedTime();fill();
}


function shiftIsoDate(date,days){
  const d=new Date(date+'T12:00:00');
  d.setDate(d.getDate()+days);
  return d.toISOString().slice(0,10)
}
function suggestedCopyTargetDate(){
  const dates=(state.data.dietPlan||[]).map(x=>x.date).filter(Boolean).sort();
  return dates.length?shiftIsoDate(dates[dates.length-1],1):new Date().toISOString().slice(0,10)
}
function copyPreviousDayForm(){
  const target=suggestedCopyTargetDate();
  openModal('Skopiuj poprzedni dzień',`<div class="form-grid"><label class="full">Dzień docelowy<input name="targetDate" id="copyTargetDate" type="date" required value="${target}"></label><div class="full panel copy-day-info"><p id="copyDayInfo"></p><p class="hint">Skopiowane zostaną godziny, typy posiłków, przepisy i liczba porcji. Jeżeli dzień docelowy zawiera już posiłki, możesz je zastąpić.</p></div></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Skopiuj</button></div>`,async fd=>{
    const targetDate=fd.get('targetDate');
    const sourceDate=shiftIsoDate(targetDate,-1);
    const sourceMeals=(state.data.dietPlan||[]).filter(x=>x.date===sourceDate);
    if(!sourceMeals.length){toast('Poprzedni dzień nie zawiera posiłków');return}
    const existing=(state.data.dietPlan||[]).filter(x=>x.date===targetDate);
    if(existing.length&&!await confirmDialog({title:'Zastąpić plan dnia?',message:`Dzień ${targetDate} zawiera już ${existing.length} pozycji.`,confirmLabel:'Zastąp'}))return;
    state.data.dietPlan=(state.data.dietPlan||[]).filter(x=>x.date!==targetDate);
    state.data.dietPlan.push(...sourceMeals.map(m=>({
      id:uid(),date:targetDate,time:m.time||'',mealType:m.mealType||'Inne',recipeId:m.recipeId,portions:Math.max(0.25,num(m.portions)||1)
    })));
    closeModal();
    await save();
    toast(`Skopiowano ${sourceMeals.length} posiłków z ${sourceDate}`)
  });
  const updateInfo=()=>{const targetDate=$('#copyTargetDate').value,sourceDate=targetDate?shiftIsoDate(targetDate,-1):'',count=(state.data.dietPlan||[]).filter(x=>x.date===sourceDate).length;$('#copyDayInfo').innerHTML=targetDate?`Źródło: <strong>${esc(sourceDate)}</strong> · ${count} ${count===1?'posiłek':'posiłków'}`:''};
  $('#copyTargetDate').oninput=updateInfo;
  updateInfo()
}

function pdfDateLabel(date){return new Date(date+'T12:00:00').toLocaleDateString('pl-PL',{weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'})}
function romanMealNumber(index){return ['I','II','III','IV','V','VI','VII','VIII'][index]||String(index+1)}
function printableMealHtml(m,index){
  const r=recipeById(m.recipeId);if(!r)return '';
  const portions=Math.max(0.25,num(m.portions)||1),n=recipeNutrition(r);
  const ingredients=(r.ingredients||[]).map(i=>{const p=productById(i.productId),unit=i.unit||p?.baseUnit||'g';const amount=(i.amount!=null?num(i.amount):(ingredientBaseAmount(i,p)/unitFactor(p,unit)))*portions;const base=ingredientBaseAmount(i,p)*portions;const baseText=(unit!==p?.baseUnit&&p?.baseUnit)?` (${fmt(base)} ${esc(p.baseUnit)})`:'';return `<li>${esc(p?.name||'Nieznany produkt')} - ${fmt(amount)} ${esc(unit)}${baseText}</li>`}).join('');
  return `<article class="pdf-meal"><div class="pdf-meal-top"><div><div class="pdf-time">${esc(m.time||'--:--')} <span class="pdf-meal-type">${esc(m.mealType||`Posiłek ${romanMealNumber(index)}`)}</span></div><div class="pdf-date-small">${esc(pdfDateLabel(m.date))}</div></div><div class="pdf-nutrition"><b>WARTOŚCI<br>ODŻYWCZE:</b><span>Energia: ${fmt(n.kcal*portions)} kcal</span><span>Białko: ${fmt(n.protein*portions)} g</span><span>Tłuszcz: ${fmt(n.fat*portions)} g</span><span>Węglowodany: ${fmt(n.carbs*portions)} g</span></div></div><h2>${esc(r.name)}</h2>${portions!==1?`<div class="pdf-portions">Liczba porcji: ${fmt(portions)}</div>`:''}<h3>SKŁADNIKI:</h3><ul>${ingredients||'<li>Brak składników</li>'}</ul><h3>SPOSÓB PRZYGOTOWANIA:</h3><div class="pdf-instructions">${esc(r.instructions||'Brak opisu przygotowania.').replace(/\n/g,'<br>')}</div></article>`
}
function buildPrintablePlan(from,to){
  const meals=[...state.data.dietPlan].filter(m=>(!from||m.date>=from)&&(!to||m.date<=to)).sort((a,b)=>a.date.localeCompare(b.date)||(a.time||'').localeCompare(b.time||''));
  const groups=meals.reduce((a,m)=>((a[m.date]??=[]).push(m),a),{});
  const days=Object.entries(groups).map(([date,items])=>`<section class="pdf-day"><header class="pdf-day-header"><strong>Moja Dieta - indywidualny plan żywieniowy</strong><span>${esc(pdfDateLabel(date))}</span></header><div class="pdf-meals pdf-cols-${Math.min(Math.max(items.length,1),4)}">${items.map((m,i)=>printableMealHtml(m,i)).join('')}</div><footer>Wygenerowano ${new Date().toLocaleDateString('pl-PL')}</footer></section>`).join('');
  return `<!doctype html><html lang="pl"><head><meta charset="utf-8"><title>Plan diety ${esc(from||'')} ${esc(to||'')}</title><style>
  @page{size:A4 landscape;margin:8mm}
*{box-sizing:border-box}
body{margin:0;font-family:Arial,Helvetica,sans-serif;color:#171717;background:#eee;font-size:8pt;line-height:1.35}
.print-toolbar{position:sticky;top:0;z-index:2;padding:10px 14px;background:#1f6b49;color:white;display:flex;align-items:center;justify-content:space-between;gap:12px;font-size:9pt}
.print-toolbar button{border:0;border-radius:8px;padding:9px 14px;font-size:9pt;font-weight:700;cursor:pointer}
.pdf-day{background:white;width:281mm;min-height:194mm;margin:10px auto;padding:3mm 2mm 7mm;position:relative;page-break-after:always}
.pdf-day:last-child{page-break-after:auto}
.pdf-day-header{display:flex;justify-content:space-between;align-items:center;border-bottom:.3mm solid #b8b8b8;padding:0 1mm 2mm;margin-bottom:3mm;color:#555;font-size:7.5pt;line-height:1.2}
.pdf-day-header strong{font-size:8.5pt;color:#222}
.pdf-meals{display:grid;gap:4mm;align-items:start}
.pdf-cols-1{grid-template-columns:1fr}.pdf-cols-2{grid-template-columns:repeat(2,1fr)}.pdf-cols-3{grid-template-columns:repeat(3,1fr)}.pdf-cols-4{grid-template-columns:repeat(4,1fr)}
.pdf-meal{min-width:0;padding:0 1mm;font-size:8pt;line-height:1.35;break-inside:avoid}
.pdf-meal-top{display:grid;grid-template-columns:minmax(0,1fr) 30mm;gap:2.5mm;align-items:start}
.pdf-time{font-size:10pt;font-weight:700;line-height:1.15}
.pdf-meal-type{font-weight:700}
.pdf-date-small{font-size:8.5pt;font-weight:700;line-height:1.2;margin-top:1mm}
.pdf-nutrition{font-size:6.75pt;line-height:1.25;color:#333}
.pdf-nutrition b{display:block;font-size:7pt;line-height:1.05;margin-bottom:.8mm;text-decoration:underline}
.pdf-nutrition span{display:block}
.pdf-meal h2{font-size:11pt;font-weight:700;line-height:1.16;margin:3mm 0 3.5mm}
.pdf-portions{font-size:7pt;line-height:1.2;margin-top:-2.5mm;margin-bottom:2.5mm;color:#666}
.pdf-meal h3{font-size:8.5pt;font-weight:700;line-height:1.15;text-decoration:underline;margin:3mm 0 1.6mm;letter-spacing:.01em}
.pdf-meal ul{list-style:none;padding:0;margin:0;font-size:7.8pt;line-height:1.32}
.pdf-meal li{margin:0 0 .9mm}
.pdf-instructions{font-size:7.8pt;line-height:1.38;white-space:normal}
.pdf-day footer{position:absolute;bottom:2mm;left:3mm;font-size:6.25pt;line-height:1;color:#777}
@media print{body{background:white}.print-toolbar{display:none}.pdf-day{margin:0;width:auto;min-height:0;padding-top:0}}
  </style></head><body><div class="print-toolbar"><span>Podgląd planu diety</span><button onclick="window.print()">Zapisz jako PDF / Drukuj</button></div>${days||'<div style="padding:30px">Brak posiłków w wybranym zakresie dat.</div>'}</body></html>`
}
function openPrintablePlan(from,to){const w=window.open('','_blank');if(!w){toast('Przeglądarka zablokowała nowe okno');return}w.document.open();w.document.write(buildPrintablePlan(from,to));w.document.close();setTimeout(()=>{try{w.focus();w.print()}catch{}},500)}
function cookSeveralDaysForm(recipe,defaults={}){if(!recipe)return;const today=defaults.startDate||new Date().toISOString().slice(0,10);openModal('Gotowanie na kilka dni',`<div class="form-grid"><div class="full panel"><h3>${esc(recipe.name)}</h3><p>Przepis zostanie dodany do planu na kolejne dni, a składniki automatycznie trafią do koszyka po wygenerowaniu listy.</p></div><label>Data rozpoczęcia<input name="startDate" type="date" required value="${today}"></label><label>Liczba dni<input name="days" type="number" min="2" max="14" step="1" required value="3"></label><label>Typ posiłku<select name="mealType">${['Śniadanie','II śniadanie','Obiad','Podwieczorek','Kolacja','Przekąska','Inne'].map(x=>`<option ${x===(defaults.mealType||recipe.mealType)?'selected':''}>${x}</option>`).join('')}</select></label><label>Godzina<input name="time" type="time" value="${defaults.time||suggestedMealTime(defaults.mealType||recipe.mealType)}"></label><label>Liczba porcji dziennie<input name="portions" type="number" min="0.25" step="0.25" value="${defaults.portions||1}"></label><label class="checkbox-field"><input name="replace" type="checkbox"> Zastąp ten sam typ posiłku w wybranych dniach</label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Dodaj do planu</button></div>`,async fd=>{const start=fd.get('startDate'),days=Math.max(2,Math.min(14,num(fd.get('days'))||2)),mealType=fd.get('mealType'),time=fd.get('time'),portions=Math.max(.25,num(fd.get('portions'))||1),replace=fd.get('replace')==='on';for(let i=0;i<days;i++){const date=shiftIsoDate(start,i);if(replace)state.data.dietPlan=state.data.dietPlan.filter(m=>!(m.date===date&&m.mealType===mealType));state.data.dietPlan.push({id:uid(),date,time,mealType,recipeId:recipe.id,portions})}await closeModal(true);await save();toast(`Dodano przepis na ${days} dni`)})}
function shoppingPreset(days){const from=new Date().toISOString().slice(0,10);$('#shoppingFrom').value=from;$('#shoppingTo').value=shiftIsoDate(from,days-1)}
function pdfExportForm(){
  const dates=state.data.dietPlan.map(m=>m.date).filter(Boolean).sort();const today=new Date().toISOString().slice(0,10),from=dates[0]||today,to=dates[dates.length-1]||today;
  openModal('Eksport planu do PDF',`<div class="form-grid"><label>Data od<input name="from" type="date" required value="${from}"></label><label>Data do<input name="to" type="date" required value="${to}"></label><div class="full panel pdf-export-note"><b>Układ wydruku</b><p>Pozioma strona A4, jeden dzień na stronie, posiłki w kolumnach. Po otwarciu podglądu wybierz w oknie drukowania opcję „Zapisz jako PDF”.</p></div></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Utwórz PDF</button></div>`,fd=>{const from=fd.get('from'),to=fd.get('to');if(from>to){toast('Data od nie może być późniejsza niż data do');return}closeModal();openPrintablePlan(from,to)})
}

const MEAL_TYPES=['Śniadanie','II śniadanie','Obiad','Podwieczorek','Kolacja','Przekąska','Inne'];
function dayCompleteness(date,meals){const targets=state.data.settings?.targets||{},n=mealsNutrition(meals),missing=['Śniadanie','Obiad','Kolacja'].filter(t=>!meals.some(m=>m.mealType===t));const delta=num(targets.kcal)?(n.kcal-num(targets.kcal))/num(targets.kcal):0;if(!meals.length)return {kind:'empty',label:'Brak planu',detail:'Dodaj pierwszy posiłek'};if(delta>.15)return {kind:'over',label:'Przekroczony',detail:`+${fmt(n.kcal-num(targets.kcal))} kcal`};if(missing.length)return {kind:'incomplete',label:'Niepełny',detail:`Brakuje: ${missing.join(', ')}`};if(delta<-.15)return {kind:'incomplete',label:'Niepełny',detail:`Pozostało ${fmt(num(targets.kcal)-n.kcal)} kcal`};return {kind:'complete',label:'Kompletny',detail:`${fmt(n.kcal)} / ${fmt(targets.kcal)} kcal`}}
function dayCompletenessHtml(date,meals){const s=dayCompleteness(date,meals);return `<div class="day-completeness ${s.kind}"><b>${s.label}</b><span>${esc(s.detail)}</span></div>`}
function updateMealImpactPreview(editId=''){const el=$('#mealImpactPreview');if(!el)return;const recipe=recipeById($('#recipeSelect')?.value),date=$('#modalForm [name=date]')?.value,portions=Math.min(3,Math.max(.25,num($('#mealPortions')?.value)||1));if(!recipe||!date){el.innerHTML='';return}const before=mealsNutrition(state.data.dietPlan.filter(x=>x.date===date&&x.id!==editId)),rn=recipeNutrition(recipe),after={kcal:before.kcal+rn.kcal*portions,protein:before.protein+rn.protein*portions,fat:before.fat+rn.fat*portions,carbs:before.carbs+rn.carbs*portions},t=state.data.settings?.targets||{};el.innerHTML=`<div class="meal-impact ${after.kcal>num(t.kcal)?'over':''}"><h3>Po dodaniu</h3><div><b>${fmt(after.kcal)} / ${fmt(t.kcal)} kcal</b><span>B ${fmt(after.protein)} / ${fmt(t.protein)} g</span><span>T ${fmt(after.fat)} / ${fmt(t.fat)} g</span><span>W ${fmt(after.carbs)} / ${fmt(t.carbs)} g</span></div><p>${after.kcal>num(t.kcal)?`Przekroczysz cel o ${fmt(after.kcal-num(t.kcal))} kcal.`:`Pozostanie około ${fmt(Math.max(0,num(t.kcal)-after.kcal))} kcal.`}</p></div>`}
function recentRecipes(type){const ids=[...state.data.dietPlan].sort((a,b)=>b.date.localeCompare(a.date)).map(m=>m.recipeId);return [...new Set(ids)].map(recipeById).filter(r=>r&&r.mealType===type).slice(0,5)}
function quickMealForm(defaults={}){let date=defaults.date||state.selectedPlanDate||new Date().toISOString().slice(0,10),type=defaults.mealType||'Śniadanie';openModal('Szybkie dodawanie',`<div class="quick-add-head"><label>Data<input id="quickMealDate" type="date" value="${date}"></label><label>Typ posiłku<select id="quickMealType">${MEAL_TYPES.map(x=>`<option ${x===type?'selected':''}>${x}</option>`).join('')}</select></label></div><label>Szukaj przepisu<input id="quickRecipeSearch" type="search" autocomplete="off" placeholder="Zacznij wpisywać nazwę…"></label><div class="quick-recipe-tabs"><button type="button" class="secondary active" data-quick-filter="recommended">Polecane</button><button type="button" class="secondary" data-quick-filter="recent">Ostatnie</button><button type="button" class="secondary" data-quick-filter="favorite">Ulubione</button></div><div id="quickRecipeResults" class="quick-recipe-results"></div><button type="button" id="quickMoreOptions" class="secondary full-width">Więcej opcji</button>`,()=>{});let filter='recommended';const syncContext=()=>{$('#modal').dataset.quickDate=date;$('#modal').dataset.quickType=type};const draw=()=>{syncContext();const q=($('#quickRecipeSearch').value||'').toLowerCase(),all=state.data.recipes.filter(r=>r.mealType===type&&(!q||r.name.toLowerCase().includes(q)));let rs=all;if(filter==='recent')rs=recentRecipes(type).filter(r=>!q||r.name.toLowerCase().includes(q));if(filter==='favorite')rs=all.filter(r=>r.favorite);rs=rs.sort((a,b)=>(b.favorite?1:0)-(a.favorite?1:0)||a.name.localeCompare(b.name)).slice(0,12);$('#quickRecipeResults').innerHTML=rs.length?rs.map(r=>{const n=recipeNutrition(r);return `<button type="button" class="quick-recipe-card" data-quick-recipe="${r.id}"><span><b>${r.favorite?'★ ':''}${esc(r.name)}</b><small>${fmt(n.kcal)} kcal · B ${fmt(n.protein)} g</small></span><strong>Dodaj</strong></button>`}).join(''):empty('Brak pasujących przepisów')};$('#quickRecipeSearch').oninput=draw;$('#quickMealDate').onchange=e=>{date=e.target.value;draw()};$('#quickMealType').onchange=e=>{type=e.target.value;draw()};$$('[data-quick-filter]').forEach(b=>b.onclick=()=>{$$('[data-quick-filter]').forEach(x=>x.classList.remove('active'));b.classList.add('active');filter=b.dataset.quickFilter;draw()});$('#quickMoreOptions').onclick=async()=>{await closeModal(true);mealForm({date,mealType:type,time:suggestedMealTime(type),portions:1,_new:true})};draw()}
async function addQuickRecipe(recipeId,date,type){state.data.dietPlan.push({id:uid(),date,time:suggestedMealTime(type),mealType:type,recipeId,portions:1});await closeModal(true);await save();toast('Posiłek dodany')}
function copyMealForm(meal){if(!meal)return;const days=Array.from({length:14},(_,i)=>shiftIsoDate(meal.date,i+1));openModal('Kopiuj posiłek',`<div class="panel"><b>${esc(recipeById(meal.recipeId)?.name||'Posiłek')}</b><p>${esc(meal.mealType)} · ${esc(meal.time)} · ${fmt(meal.portions)} por.</p></div><p>Wybierz dni docelowe:</p><div class="date-check-grid">${days.map(d=>`<label><input type="checkbox" name="dates" value="${d}"> ${new Date(d+'T12:00').toLocaleDateString('pl-PL',{weekday:'short',day:'2-digit',month:'2-digit'})}</label>`).join('')}</div><label class="checkbox-field"><input type="checkbox" name="replace"> Zastąp posiłek tego samego typu</label><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Kopiuj</button></div>`,async fd=>{const dates=fd.getAll('dates'),replace=fd.get('replace')==='on';if(!dates.length)return toast('Wybierz co najmniej jeden dzień');for(const date of dates){if(replace)state.data.dietPlan=state.data.dietPlan.filter(x=>!(x.date===date&&x.mealType===meal.mealType));state.data.dietPlan.push({...meal,id:uid(),date})}await closeModal(true);await save();toast(`Skopiowano na ${dates.length} dni`)})}
function repeatMealForm(meal){if(!meal)return;openModal('Powtarzaj posiłek',`<div class="form-grid"><label>Od daty<input name="start" type="date" value="${meal.date}" required></label><label>Do daty<input name="end" type="date" value="${shiftIsoDate(meal.date,14)}" required></label><label>Powtarzaj<select name="mode"><option value="daily">Codziennie</option><option value="alternate">Co 2 dni</option><option value="weekdays">Wybrane dni tygodnia</option></select></label><div class="full weekday-picker">${['Pn','Wt','Śr','Cz','Pt','So','Nd'].map((x,i)=>`<label><input type="checkbox" name="weekday" value="${i+1}" ${i<5?'checked':''}>${x}</label>`).join('')}</div><label class="checkbox-field full"><input type="checkbox" name="replace"> Zastępuj ten sam typ posiłku</label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zaplanuj</button></div>`,async fd=>{const start=fd.get('start'),end=fd.get('end'),mode=fd.get('mode'),weekdays=fd.getAll('weekday').map(Number),replace=fd.get('replace')==='on';let count=0;for(let d=start,i=0;d<=end;d=shiftIsoDate(d,1),i++){const jsday=new Date(d+'T12:00').getDay()||7,ok=mode==='daily'||(mode==='alternate'&&i%2===0)||(mode==='weekdays'&&weekdays.includes(jsday));if(!ok||d===meal.date)continue;if(replace)state.data.dietPlan=state.data.dietPlan.filter(x=>!(x.date===d&&x.mealType===meal.mealType));state.data.dietPlan.push({...meal,id:uid(),date:d});count++}await closeModal(true);await save();toast(`Dodano ${count} powtórzeń`)})}
function moveMealForm(meal){if(!meal)return;openModal('Przenieś posiłek',`<div class="form-grid"><label>Nowa data<input name="date" type="date" required value="${meal.date}"></label><label>Nowa godzina<input name="time" type="time" value="${meal.time}"></label><label>Typ posiłku<select name="mealType">${MEAL_TYPES.map(x=>`<option ${x===meal.mealType?'selected':''}>${x}</option>`).join('')}</select></label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Przenieś</button></div>`,async fd=>{meal.date=fd.get('date');meal.time=fd.get('time');meal.mealType=fd.get('mealType');state.selectedPlanDate=meal.date;await closeModal(true);await save();toast('Posiłek przeniesiony')})}
function mealDetailsPanel(meal){if(!meal)return;const r=recipeById(meal.recipeId),n=recipeNutrition(r||{ingredients:[]}),p=Math.max(.25,num(meal.portions)||1);openPlanningPanel(`<div class="planner-panel-head"><div><span class="badge">${esc(meal.mealType)}</span><h2>${esc(r?.name||'Posiłek')}</h2><p>${esc(meal.date)} · ${esc(meal.time)} · ${fmt(p)} por.</p></div><button class="icon-btn" data-close-planner>×</button></div><div class="planner-nutrition"><b>${fmt(n.kcal*p)} kcal</b><span>B ${fmt(n.protein*p)} g</span><span>T ${fmt(n.fat*p)} g</span><span>W ${fmt(n.carbs*p)} g</span></div><div class="planner-actions"><button class="primary" data-edit-meal="${meal.id}">Edytuj</button><button class="secondary" data-copy-meal="${meal.id}">Kopiuj</button><button class="secondary" data-repeat-meal="${meal.id}">Powtarzaj</button><button class="secondary" data-move-meal="${meal.id}">Przenieś</button><button class="danger-btn" data-delete-meal="${meal.id}">Usuń</button></div>`)}
function dayDetailsPanel(date){const meals=state.data.dietPlan.filter(m=>m.date===date).sort((a,b)=>(a.time||'').localeCompare(b.time||''));openPlanningPanel(`<div class="planner-panel-head"><div><h2>${new Date(date+'T12:00').toLocaleDateString('pl-PL',{weekday:'long',day:'numeric',month:'long'})}</h2>${dayCompletenessHtml(date,meals)}</div><button class="icon-btn" data-close-planner>×</button></div>${daySummaryHtml(meals)}${planWarnings(meals)}<div class="planner-actions"><button class="primary" data-quick-add-date="${date}">Dodaj posiłek</button><button class="secondary" data-action="copy-day-many" data-source-date="${date}">Kopiuj dzień</button><button class="danger-btn" data-delete-day="${date}">Wyczyść dzień</button></div>`)}
function openPlanningPanel(html){const el=$('#planningPanel');el.innerHTML=`<div class="planning-panel-card">${html}</div>`;el.classList.remove('hidden');el.setAttribute('aria-hidden','false')}
function closePlanningPanel(){const el=$('#planningPanel');if(el){el.classList.add('hidden');el.setAttribute('aria-hidden','true');el.innerHTML=''}}
function measurementForm(m){openModal(m?'Edytuj pomiar':'Dodaj pomiar',`<div class="form-grid"><label>Data<input name="date" type="date" required value="${m?.date||new Date().toISOString().slice(0,10)}"></label><label>Masa (kg)<input name="weight" type="number" step="0.1" value="${m?.weight??''}"></label><label>Talia (cm)<input name="waist" type="number" step="0.1" value="${m?.waist??''}"></label><label>Klatka piersiowa (cm)<input name="chest" type="number" step="0.1" value="${m?.chest??''}"></label><label class="full">Notatki<textarea name="notes">${esc(m?.notes||'')}</textarea></label></div><div class="form-actions"><button type="button" class="secondary" data-close>Anuluj</button><button class="primary">Zapisz</button></div>`,async fd=>{const x={id:m?.id||uid(),date:fd.get('date'),weight:num(fd.get('weight'))||null,waist:num(fd.get('waist'))||null,chest:num(fd.get('chest'))||null,notes:fd.get('notes').trim()};m?Object.assign(m,x):state.data.measurements.push(x);closeModal();await save()})}
document.addEventListener('click',async e=>{const t=e.target.closest('button,[data-nav],[data-toggle-shopping],[data-toggle-favorite],[data-duplicate-recipe],[data-add-meal-date],[data-cook-days],[data-shopping-preset]');if(!t)return;if(t.dataset.view)return go(t.dataset.view);if(t.dataset.nav)return go(t.dataset.nav);if(t.dataset.close!==undefined)return closeModal();if(t.dataset.closePlanner!==undefined){closePlanningPanel();return}if(t.dataset.mobileDay){state.selectedPlanDate=t.dataset.mobileDay;renderPlan();return}if(t.dataset.dayDetails){dayDetailsPanel(t.dataset.dayDetails);return}if(t.dataset.mealDetails){mealDetailsPanel(state.data.dietPlan.find(x=>x.id===t.dataset.mealDetails));return}if(t.dataset.quickAddDate){quickMealForm({date:t.dataset.quickAddDate,mealType:t.dataset.quickAddType||'Śniadanie'});return}if(t.dataset.quickRecipe){addQuickRecipe(t.dataset.quickRecipe,$('#modal').dataset.quickDate||state.selectedPlanDate||new Date().toISOString().slice(0,10),$('#modal').dataset.quickType||'Śniadanie');return}if(t.dataset.copyMeal){copyMealForm(state.data.dietPlan.find(x=>x.id===t.dataset.copyMeal));return}if(t.dataset.repeatMeal){repeatMealForm(state.data.dietPlan.find(x=>x.id===t.dataset.repeatMeal));return}if(t.dataset.moveMeal){moveMealForm(state.data.dietPlan.find(x=>x.id===t.dataset.moveMeal));return}if(t.dataset.toggleFavorite){const r=recipeById(t.dataset.toggleFavorite);if(r){r.favorite=!r.favorite;await save()}return}if(t.dataset.duplicateRecipe){const r=recipeById(t.dataset.duplicateRecipe);if(r){const copy=structuredClone(r);copy.id=uid();copy.name=`${r.name} – kopia`;copy.favorite=false;state.data.recipes.push(copy);await save();toast('Przepis został zduplikowany')}return}if(t.dataset.cookDays){return cookSeveralDaysForm(recipeById(t.dataset.cookDays))}if(t.dataset.shoppingPreset){shoppingPreset(num(t.dataset.shoppingPreset));return}if(t.dataset.addMealDate){quickMealForm({date:t.dataset.addMealDate,mealType:t.dataset.addMealType||'Śniadanie'});return}if(t.dataset.sourceDate)state.copySourceDate=t.dataset.sourceDate;if(t.dataset.action&&actions[t.dataset.action])return actions[t.dataset.action]();if(t.dataset.toggleShopping){const x=(state.data.shoppingList||[]).find(i=>i.id===t.dataset.toggleShopping);if(x){x.purchased=!x.purchased;await save()}return}if(t.dataset.deleteDay){
  const date=t.dataset.deleteDay;
  const dayMeals=state.data.dietPlan.filter(m=>m.date===date);
  if(!dayMeals.length){toast('Ten dzień nie zawiera posiłków');return}
  const label=new Date(date+'T12:00:00').toLocaleDateString('pl-PL',{weekday:'long',day:'numeric',month:'long'});
  if(await confirmDialog({title:'Usunąć cały dzień?',message:`${label}\nLiczba posiłków: ${dayMeals.length}`,confirmLabel:'Usuń dzień',danger:true})){
    const before=structuredClone(state.data);
    state.data.dietPlan=state.data.dietPlan.filter(m=>m.date!==date);
    await save();
    toast(`Usunięto cały dzień (${dayMeals.length} posiłków)`,'Cofnij',async()=>{
      const currentUpdatedAt=state.data.updatedAt;
      state.data=before;
      state.data.updatedAt=currentUpdatedAt;
      state.loadedUpdatedAt=currentUpdatedAt;
      await save();
      toast('Usunięcie dnia cofnięte');
    },7000)
  }
  return
}
const map=[['editProduct','products',productForm],['deleteProduct','products'],['editRecipe','recipes',recipeForm],['deleteRecipe','recipes'],['editMeal','dietPlan',mealForm],['deleteMeal','dietPlan'],['editMeasurement','measurements',measurementForm],['deleteMeasurement','measurements'],['editShopping','shoppingList',shoppingForm],['deleteShopping','shoppingList']];for(const [key,arr,fn] of map){const id=t.dataset[key];if(id){const obj=state.data[arr].find(x=>x.id===id);if(key.startsWith('edit'))return fn(obj);if(await confirmDialog({title:'Usunąć element?',message:'Tej operacji można będzie cofnąć przez 7 sekund.',confirmLabel:'Usuń',danger:true})){const before=structuredClone(state.data);state.data[arr]=state.data[arr].filter(x=>x.id!==id);if(arr==='products')state.data.recipes.forEach(r=>r.ingredients=(r.ingredients||[]).filter(i=>i.productId!==id));if(arr==='recipes')state.data.dietPlan=state.data.dietPlan.filter(x=>x.recipeId!==id);await save();toast('Element został usunięty','Cofnij',async()=>{const currentUpdatedAt=state.data.updatedAt;state.data=before;state.data.updatedAt=currentUpdatedAt;state.loadedUpdatedAt=currentUpdatedAt;await save();toast('Usunięcie cofnięte')},7000)}return}}});
const modalClose=$('#modalClose'),modal=$('#modal'),syncBtn=$('#syncBtn'),installBtn=$('#installBtn');if(modalClose)modalClose.onclick=closeModal;if(modal)modal.addEventListener('click',e=>{if(e.target.id==='modal')closeModal()});$('#moreSheet')?.addEventListener('click',e=>{if(e.target.id==='moreSheet')closeMore()});document.addEventListener('keydown',e=>{if(e.key==='Escape'){if(!$('#modal').classList.contains('hidden'))closeModal();else closeMore()}});if(syncBtn)syncBtn.onclick=load;
document.addEventListener('click',e=>{const remove=e.target.closest('.ingredient-remove');if(remove){const row=remove.closest('[data-ingredient-row]');if($('#ingredientRows')?.children.length===1){row.querySelectorAll('input').forEach(x=>x.value='');row.querySelector('[name="productId"]').value='';row.querySelector('.ingredient-conversion').textContent='Wybierz produkt i ilość, aby zobaczyć przeliczenie.'}else row.remove();$('#modal').dataset.recipeDirty='true';saveRecipeDraft($('#modal').dataset.recipeDraftKey||RECIPE_DRAFT_PREFIX+'new')}});
function updateIngredientConversion(row){if(!row)return;const p=productById(row.querySelector('[name="productId"]')?.value),amount=num(row.querySelector('[name="ingredientAmount"]')?.value),unit=row.querySelector('[name="ingredientUnit"]')?.value||p?.baseUnit||'g',el=row.querySelector('.ingredient-conversion');if(el)el.textContent=p&&amount>0?`${fmt(amount)} ${unit} = ${fmt(amount*unitFactor(p,unit))} ${p.baseUnit||'g'}`:'Wybierz produkt i ilość, aby zobaczyć przeliczenie.'}
document.addEventListener('input',e=>{if(e.target.matches('[name="ingredientAmount"]'))updateIngredientConversion(e.target.closest('[data-ingredient-row]'))});
document.addEventListener('change',e=>{if(e.target.matches('.ingredient-unit-select'))updateIngredientConversion(e.target.closest('[data-ingredient-row]'))});
document.addEventListener('input',e=>{if(e.target.matches('.ingredient-product-search')){const select=document.getElementById(e.target.dataset.target);if(!select)return;const current=select.value;select.innerHTML=`<option value="">Wybierz…</option>${productOptions(current,e.target.value)}`;if(current&&[...select.options].some(o=>o.value===current))select.value=current}});
document.addEventListener('change',e=>{if(e.target.matches('.ingredient-product-select')){const p=productById(e.target.value),unit=document.getElementById(e.target.dataset.unitTarget);if(unit)unit.innerHTML=p?unitOptions(p,p.baseUnit):'<option value="g">g</option>';updateIngredientConversion(e.target.closest('[data-ingredient-row]'))}});
document.addEventListener('change',async e=>{if(e.target.id==='jsonImport'){const file=e.target.files[0];if(!file)return;try{const d=JSON.parse(await file.text());if(!Array.isArray(d.products)||!Array.isArray(d.recipes)||!Array.isArray(d.dietPlan)||!Array.isArray(d.measurements))throw Error('Nieprawidłowy format');d.shoppingList=Array.isArray(d.shoppingList)?d.shoppingList:[];const legacy=num(d.version)<3;d.products=d.products.map(p=>normalizeProductUnits({...p,category:normalizeCategory(p.category,p.name,legacy)}));d.shoppingList=d.shoppingList.map(x=>({...x,category:normalizeCategory(x.category,x.name,legacy)}));d.dietPlan=d.dietPlan.map(m=>({...m,portions:Math.max(0.25,num(m.portions)||1)}));d.version=5;if(await confirmDialog({title:'Zaimportować plik JSON?',message:'Wszystkie aktualne dane zostaną zastąpione zawartością pliku.',confirmLabel:'Importuj'})){state.data=d;await save()}}catch(err){toast('Nieprawidłowy plik JSON')}finally{e.target.value=''}}if(e.target.id==='excelImport'){const file=e.target.files[0];if(!file)return;try{await importExcel(file)}catch(err){console.error(err);toast(`Błąd importu Excel: ${err.message}`)}finally{e.target.value=''}}});
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();state.installPrompt=e;if(installBtn)installBtn.classList.remove('hidden')});if(installBtn)installBtn.onclick=async()=>{if(state.installPrompt){state.installPrompt.prompt();await state.installPrompt.userChoice;state.installPrompt=null;installBtn.classList.add('hidden')}};
render();
if('serviceWorker'in navigator)window.addEventListener('load',()=>navigator.serviceWorker.register('/service-worker.js').catch(console.error));
load();
